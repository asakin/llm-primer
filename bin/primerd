#!/usr/bin/env bash
# primerd — llm-primer daemon
# Manages pre-warmed Claude Code sessions in tmux.
#
# Two modes:
#   lazy (default) — pool starts empty. Sessions warm on demand when Claude
#                    signals via ~/.llm-primer/warm-request (PostCompact hook,
#                    CLAUDE.md instruction, or `primer warm`). Zero idle cost.
#   eager           — always keeps PRIMER_POOL_SIZE sessions warm. Set
#                    PRIMER_MODE=eager to opt in.

set -euo pipefail

PRIMER_DIR="${PRIMER_DIR:-$HOME/.llm-primer}"
PRIMER_SESSION_PREFIX="${PRIMER_SESSION_PREFIX:-primer}"
PRIMER_POOL_SIZE="${PRIMER_POOL_SIZE:-2}"
PRIMER_MODE="${PRIMER_MODE:-lazy}"        # lazy | eager
PRIMER_CLI="${PRIMER_CLI:-claude}"        # command to launch the LLM session
PRIMER_WARMUP_MSG="${PRIMER_WARMUP_MSG:-ready}"
PRIMER_WARMUP_MARKER="${PRIMER_WARMUP_MARKER:-SESSION START}"
PRIMER_WARMUP_TIMEOUT="${PRIMER_WARMUP_TIMEOUT:-60}"
PRIMER_WATCH_INTERVAL="${PRIMER_WATCH_INTERVAL:-5}"
PRIMER_PID_FILE="$PRIMER_DIR/primerd.pid"
PRIMER_LOG_FILE="$PRIMER_DIR/primerd.log"
PRIMER_STATE_DIR="$PRIMER_DIR/state"
PRIMER_WARM_REQUEST="$PRIMER_DIR/warm-request"  # touch this to trigger lazy warm

# Directory to watch for config changes (triggers /clear + rewarm)
PRIMER_WATCH_DIR="${PRIMER_WATCH_DIR:-}"

# The tmux session that holds the pool
TMUX_SESSION="$PRIMER_SESSION_PREFIX-pool"

log() {
  echo "$(date '+%Y-%m-%d %H:%M:%S') $*" | tee -a "$PRIMER_LOG_FILE"
}

die() {
  log "ERROR: $*" >&2
  exit 1
}

require() {
  command -v "$1" &>/dev/null || die "'$1' is required but not installed"
}

# ── tmux helpers ──────────────────────────────────────────────────────────────

window_name() {
  echo "${PRIMER_SESSION_PREFIX}-$1"
}

pane_content() {
  local window="$1"
  tmux capture-pane -t "${TMUX_SESSION}:${window}" -p 2>/dev/null || echo ""
}

is_warm() {
  local window="$1"
  pane_content "$window" | grep -qF "$PRIMER_WARMUP_MARKER"
}

send_keys() {
  local window="$1"
  shift
  tmux send-keys -t "${TMUX_SESSION}:${window}" "$*" Enter
}

# ── pool management ───────────────────────────────────────────────────────────

ensure_tmux_session() {
  if ! tmux has-session -t "$TMUX_SESSION" 2>/dev/null; then
    tmux new-session -d -s "$TMUX_SESSION" -n "${PRIMER_SESSION_PREFIX}-0"
    log "Created tmux session: $TMUX_SESSION"
  fi
}

# Returns the index of the next unused slot (creating it if needed), or 1 if pool is full
next_slot() {
  for slot in $(seq 0 $((PRIMER_POOL_SIZE - 1))); do
    local state
    state=$(get_state "$slot")
    if [[ "$state" == "unknown" || "$state" == "cold" ]]; then
      echo "$slot"
      return 0
    fi
  done
  # All slots occupied — find the oldest stale one
  for slot in $(seq 0 $((PRIMER_POOL_SIZE - 1))); do
    local state
    state=$(get_state "$slot")
    if [[ "$state" == "stale" ]]; then
      echo "$slot"
      return 0
    fi
  done
  return 1
}

spawn_window() {
  local slot="$1"
  local window
  window=$(window_name "$slot")

  if ! tmux list-windows -t "$TMUX_SESSION" -F '#{window_name}' 2>/dev/null | grep -q "^${window}$"; then
    tmux new-window -t "$TMUX_SESSION" -n "$window"
    log "Spawned window: $window"
  fi

  set_state "$slot" "spawned"
}

warm_window() {
  local slot="$1"
  local window
  window=$(window_name "$slot")

  log "Warming slot $slot..."
  set_state "$slot" "warming"

  local content
  content=$(pane_content "$window")
  if ! echo "$content" | grep -qF "$PRIMER_WARMUP_MARKER" && ! echo "$content" | grep -q '\$'; then
    send_keys "$window" "$PRIMER_CLI"
  fi

  sleep 2
  send_keys "$window" "$PRIMER_WARMUP_MSG"

  local waited=0
  while [[ $waited -lt $PRIMER_WARMUP_TIMEOUT ]]; do
    if is_warm "$window"; then
      log "Slot $slot is warm ✓"
      set_state "$slot" "warm"
      return 0
    fi
    sleep 2
    waited=$((waited + 2))
  done

  log "WARNING: slot $slot did not warm within ${PRIMER_WARMUP_TIMEOUT}s"
  set_state "$slot" "stale"
}

rewarm_window() {
  local slot="$1"
  local window
  window=$(window_name "$slot")

  log "Re-warming slot $slot..."
  set_state "$slot" "rewarming"

  send_keys "$window" "/clear"
  sleep 1
  send_keys "$window" "$PRIMER_WARMUP_MSG"

  local waited=0
  while [[ $waited -lt $PRIMER_WARMUP_TIMEOUT ]]; do
    if is_warm "$window"; then
      log "Slot $slot re-warmed ✓"
      set_state "$slot" "warm"
      return 0
    fi
    sleep 2
    waited=$((waited + 2))
  done

  log "WARNING: slot $slot did not re-warm within ${PRIMER_WARMUP_TIMEOUT}s"
  set_state "$slot" "stale"
}

# ── state tracking ─────────────────────────────────────────────────────────────

set_state() {
  local slot="$1"
  local state="$2"
  mkdir -p "$PRIMER_STATE_DIR"
  echo "$state" > "$PRIMER_STATE_DIR/slot-${slot}"
}

get_state() {
  local slot="$1"
  local file="$PRIMER_STATE_DIR/slot-${slot}"
  [[ -f "$file" ]] && cat "$file" || echo "unknown"
}

# ── lazy warm trigger ─────────────────────────────────────────────────────────
#
# Any process can request a warm session by touching ~/.llm-primer/warm-request.
# Intended callers:
#   - Claude Code PostCompact hook (context just got heavy → warm a replacement)
#   - CLAUDE.md instruction (Claude decides its context is long → signals itself)
#   - `primer warm` CLI command
#   - Any script
#
# primerd consumes the file (rm after read) and warms one slot.

watch_warm_request() {
  while true; do
    if [[ -f "$PRIMER_WARM_REQUEST" ]]; then
      rm -f "$PRIMER_WARM_REQUEST"
      log "Warm request received"

      local slot
      if slot=$(next_slot 2>/dev/null); then
        ensure_tmux_session
        spawn_window "$slot"
        warm_window "$slot" &
      else
        log "All slots already warm or warming — ignoring warm request"
      fi
    fi
    sleep 2
  done
}

# ── config file watcher ───────────────────────────────────────────────────────

watch_and_rewarm() {
  [[ -z "$PRIMER_WATCH_DIR" ]] && return
  [[ -d "$PRIMER_WATCH_DIR" ]] || return

  local last_hash=""

  while true; do
    local current_hash
    current_hash=$(find "$PRIMER_WATCH_DIR" -type f \( -name "*.md" -o -name "*.json" \) -print0 \
      | sort -z | xargs -0 stat -f "%m %N" 2>/dev/null \
      || find "$PRIMER_WATCH_DIR" -type f \( -name "*.md" -o -name "*.json" \) -print0 \
      | sort -z | xargs -0 stat -c "%Y %n" 2>/dev/null \
      || echo "0")
    current_hash=$(echo "$current_hash" | md5sum 2>/dev/null | cut -d' ' -f1 \
      || echo "$current_hash" | md5 2>/dev/null \
      || echo "0")

    if [[ -n "$last_hash" && "$current_hash" != "$last_hash" ]]; then
      log "Config change detected in $PRIMER_WATCH_DIR — rewarming all warm slots"
      for slot in $(seq 0 $((PRIMER_POOL_SIZE - 1))); do
        local state
        state=$(get_state "$slot")
        if [[ "$state" == "warm" ]]; then
          rewarm_window "$slot" &
        fi
      done
    fi

    last_hash="$current_hash"
    sleep "$PRIMER_WATCH_INTERVAL"
  done
}

# ── main loop ─────────────────────────────────────────────────────────────────

start_daemon() {
  require tmux
  require "$PRIMER_CLI"

  mkdir -p "$PRIMER_DIR" "$PRIMER_STATE_DIR"
  log "Starting primerd (mode: $PRIMER_MODE, pool size: $PRIMER_POOL_SIZE)"

  ensure_tmux_session

  if [[ "$PRIMER_MODE" == "eager" ]]; then
    # Eager: pre-warm the full pool immediately
    log "Eager mode: pre-warming $PRIMER_POOL_SIZE slots"
    for slot in $(seq 0 $((PRIMER_POOL_SIZE - 1))); do
      spawn_window "$slot"
      warm_window "$slot" &
    done
    wait
  else
    # Lazy: pool starts cold, warms on demand
    log "Lazy mode: pool is cold — warming on demand via $PRIMER_WARM_REQUEST"
    for slot in $(seq 0 $((PRIMER_POOL_SIZE - 1))); do
      set_state "$slot" "cold"
    done
  fi

  # Warm request watcher (lazy mode signal handler — runs in both modes)
  watch_warm_request &

  # Config file watcher
  watch_and_rewarm &

  # Health loop (eager mode: re-warm stale slots; lazy mode: no-op unless slots were warmed)
  while true; do
    if [[ "$PRIMER_MODE" == "eager" ]]; then
      for slot in $(seq 0 $((PRIMER_POOL_SIZE - 1))); do
        local state
        state=$(get_state "$slot")
        if [[ "$state" == "stale" ]] || { [[ "$state" == "warm" ]] && ! is_warm "$(window_name "$slot")"; }; then
          if [[ "$state" != "rewarming" && "$state" != "warming" ]]; then
            rewarm_window "$slot" &
          fi
        fi
      done
    fi
    sleep 10
  done
}

# ── entry point ───────────────────────────────────────────────────────────────

cmd="${1:-help}"

case "$cmd" in
  start)
    if [[ -f "$PRIMER_PID_FILE" ]] && kill -0 "$(cat "$PRIMER_PID_FILE")" 2>/dev/null; then
      echo "primerd is already running (pid $(cat "$PRIMER_PID_FILE"))"
      exit 0
    fi
    mkdir -p "$PRIMER_DIR"
    start_daemon &
    echo $! > "$PRIMER_PID_FILE"
    echo "primerd started in $PRIMER_MODE mode (pid $(cat "$PRIMER_PID_FILE"))"
    ;;
  stop)
    if [[ -f "$PRIMER_PID_FILE" ]]; then
      kill "$(cat "$PRIMER_PID_FILE")" 2>/dev/null && echo "primerd stopped" || echo "primerd was not running"
      rm -f "$PRIMER_PID_FILE"
    else
      echo "primerd is not running"
    fi
    ;;
  status)
    if [[ -f "$PRIMER_PID_FILE" ]] && kill -0 "$(cat "$PRIMER_PID_FILE")" 2>/dev/null; then
      echo "primerd: running (mode: $PRIMER_MODE, pid $(cat "$PRIMER_PID_FILE"))"
    else
      echo "primerd: not running"
    fi
    mkdir -p "$PRIMER_STATE_DIR"
    echo ""
    for slot in $(seq 0 $((PRIMER_POOL_SIZE - 1))); do
      local state
      state=$(get_state "$slot")
      local warm_indicator=""
      [[ "$state" == "warm" ]] && warm_indicator=" ✓"
      printf "  slot %s: %s%s\n" "$slot" "$state" "$warm_indicator"
    done
    ;;
  help|--help|-h)
    cat <<'HELP'
primerd — llm-primer daemon

Usage: primerd <command>

Commands:
  start    Start the daemon
  stop     Stop the daemon
  status   Show daemon and pool status

Modes:
  lazy (default)   Pool starts cold. Sessions warm on demand when Claude
                   signals via ~/.llm-primer/warm-request. Zero idle token cost.
                   Triggered by: PostCompact hook, CLAUDE.md instruction, `primer warm`.

  eager            Always keeps PRIMER_POOL_SIZE sessions warm. Set PRIMER_MODE=eager.

Configuration (environment variables):
  PRIMER_DIR              State directory (default: ~/.llm-primer)
  PRIMER_SESSION_PREFIX   Tmux window prefix (default: primer)
  PRIMER_POOL_SIZE        Max sessions in pool (default: 2)
  PRIMER_MODE             lazy | eager (default: lazy)
  PRIMER_WARMUP_MSG       Message sent to trigger session protocol (default: ready)
  PRIMER_WARMUP_MARKER    String to watch for in output (default: SESSION START)
  PRIMER_WARMUP_TIMEOUT   Seconds to wait for warmup marker (default: 60)
  PRIMER_WATCH_DIR        Config dir to watch for changes (triggers rewarm)
  PRIMER_WATCH_INTERVAL   Seconds between watch checks (default: 5)

Lazy mode setup (recommended):
  Add to Claude Code settings.json:

    "hooks": {
      "PostCompact": [{"hooks": [{"type": "command",
        "command": "touch ~/.llm-primer/warm-request"}]}]
    }

  Or add to CLAUDE.md:
    When your context is getting long, run: touch ~/.llm-primer/warm-request

HELP
    ;;
  *)
    echo "Unknown command: $cmd. Run 'primerd help' for usage."
    exit 1
    ;;
esac

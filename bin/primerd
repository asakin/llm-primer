#!/usr/bin/env bash
# primerd — llm-primer daemon.
# Manages a pool of Claude Code sessions in tmux. Two modes:
#   - warm mode (default, v0.1 behavior): single tmux session, N numbered
#     windows, each warmed by sending a prompt and waiting for a marker.
#   - hold mode (v0.2, PRIMER_HOLD=1): one tmux session per named slot, each
#     running a configurable command under an auto-respawn loop. No warmup
#     message, no marker detection — just holds live Claude sessions alive.

set -euo pipefail

for _p in /opt/homebrew/bin /usr/local/bin; do
  [[ ":$PATH:" != *":$_p:"* ]] && [[ -d "$_p" ]] && PATH="$_p:$PATH"
done
unset _p

PRIMER_CONFIG="${PRIMER_CONFIG:-$HOME/.llm-primer/config}"

_load_config() {
  [[ -f "$PRIMER_CONFIG" ]] || return 0
  while IFS='=' read -r key value; do
    [[ "$key" =~ ^[[:space:]]*# ]] && continue
    [[ -z "${key// }" ]] && continue
    key="${key// /}"
    [[ -n "${!key+set}" ]] && continue
    export "$key"="$value"
  done < "$PRIMER_CONFIG"
}

_load_config

PRIMER_DIR="${PRIMER_DIR:-$HOME/.llm-primer}"
PRIMER_SESSION_PREFIX="${PRIMER_SESSION_PREFIX:-primer}"
PRIMER_POOL_SIZE="${PRIMER_POOL_SIZE:-2}"
PRIMER_CLI="${PRIMER_CLI:-claude}"

PRIMER_RESET_CMD="${PRIMER_RESET_CMD:-/clear}"

_default_warmup_msg='llm-primer is pre-warming you. Do your normal session init, then print exactly "SESSION START" on its own line — but only once you are fully ready for a real message, not before. Later, if context gets heavy, remind the user once that they can run `primer switch` to jump to a fresh session, then drop it.'
PRIMER_WARMUP_MSG="${PRIMER_WARMUP_MSG:-$_default_warmup_msg}"

PRIMER_WARMUP_MARKER="${PRIMER_WARMUP_MARKER:-SESSION START}"
PRIMER_WARMUP_TIMEOUT="${PRIMER_WARMUP_TIMEOUT:-180}"
PRIMER_CLI_READY_WAIT="${PRIMER_CLI_READY_WAIT:-8}"

PRIMER_SLOT_COLORS="${PRIMER_SLOT_COLORS:-#0d1b2a,#1b263b}"

PRIMER_WATCH_DIR="${PRIMER_WATCH_DIR:-}"
PRIMER_WATCH_INTERVAL="${PRIMER_WATCH_INTERVAL:-5}"

# v0.2 additions — opt-in, backwards compatible.
PRIMER_HOLD="${PRIMER_HOLD:-0}"
PRIMER_SLOTS="${PRIMER_SLOTS:-}"
PRIMER_LOG_FILTER="${PRIMER_LOG_FILTER:-}"
PRIMER_HOLD_CHECK_INTERVAL="${PRIMER_HOLD_CHECK_INTERVAL:-30}"

PRIMER_PID_FILE="$PRIMER_DIR/primerd.pid"
PRIMER_LOG_FILE="$PRIMER_DIR/primerd.log"
PRIMER_STATE_DIR="$PRIMER_DIR/state"
PRIMER_WARM_REQUEST="$PRIMER_DIR/warm-request"
PRIMER_LOG_DIR="$PRIMER_DIR/logs"
TMUX_SESSION="$PRIMER_SESSION_PREFIX-pool"

log() { echo "$(date '+%Y-%m-%d %H:%M:%S') $*" | tee -a "$PRIMER_LOG_FILE"; }
die() { log "ERROR: $*" >&2; exit 1; }
require() { command -v "$1" &>/dev/null || die "'$1' is required but not installed"; }

# ── Named-slot helpers (hold mode + PRIMER_SLOTS) ──────────────────────────

declare -a SLOT_COMMANDS=()
declare -a SLOT_NAMES=()

_derive_slot_name() {
  # Extract agent name from a command like `claude --agent §sakinos` or
  # `claude --agent=§scribe`. Falls back to "Claude" for bare `claude`.
  local cmd="$1"
  if [[ "$cmd" =~ --agent[[:space:]]+([^[:space:]]+) ]]; then
    echo "${BASH_REMATCH[1]}"
  elif [[ "$cmd" =~ --agent=([^[:space:]]+) ]]; then
    echo "${BASH_REMATCH[1]}"
  else
    echo "Claude"
  fi
}

_parse_slots() {
  [[ -z "$PRIMER_SLOTS" ]] && return 0
  local IFS='|'
  read -r -a SLOT_COMMANDS <<< "$PRIMER_SLOTS"
  local seen=""
  for cmd in "${SLOT_COMMANDS[@]}"; do
    local name base
    base=$(_derive_slot_name "$cmd")
    name="$base"
    local n=2
    # Disambiguate collisions: Claude, Claude-2, Claude-3...
    while [[ ",$seen," == *",$name,"* ]]; do
      name="${base}-${n}"
      n=$((n + 1))
    done
    SLOT_NAMES+=("$name")
    seen="${seen},${name}"
  done
}

slot_session_name() {
  echo "${PRIMER_SESSION_PREFIX}-${1}"
}

set_state() { mkdir -p "$PRIMER_STATE_DIR"; echo "$2" > "$PRIMER_STATE_DIR/slot-${1}"; }
get_state() { local f="$PRIMER_STATE_DIR/slot-${1}"; [[ -f "$f" ]] && cat "$f" || echo "unknown"; }

# ── Log filter helpers ─────────────────────────────────────────────────────

_attach_log_filter() {
  local session="$1"
  local slot_label="$2"
  [[ -z "$PRIMER_LOG_FILTER" ]] && return 0
  mkdir -p "$PRIMER_LOG_DIR"
  local log_path="$PRIMER_LOG_DIR/${slot_label}.log"
  # Overwrite on (re)attach so the filter command is consistent.
  tmux pipe-pane -t "$session" -o "$PRIMER_LOG_FILTER >> '$log_path'" 2>/dev/null || \
    log "WARNING: failed to attach log filter to $session"
}

_announce_debug_mode() {
  # Sends a one-time prompt into the session telling Claude to announce the
  # logging state to the user. Runs in a background subshell so the daemon
  # main loop doesn't block on CLI startup time.
  local session="$1"
  local slot_label="$2"
  local log_path="$PRIMER_LOG_DIR/${slot_label}.log"
  local msg="DEBUG MODE is on for this session. Everything you output is being piped through a filter and appended to ${log_path} for the user's records. In your first reply, tell the user: 'DEBUG MODE — this session is being logged to ${log_path}.' Then proceed normally."
  (
    sleep "$PRIMER_CLI_READY_WAIT"
    tmux send-keys -t "$session" -l "$msg" 2>/dev/null || exit 0
    sleep 0.3
    tmux send-keys -t "$session" Enter 2>/dev/null || true
  ) &
  disown "$!" 2>/dev/null || true
}

# ── Hold mode ──────────────────────────────────────────────────────────────

ensure_hold_session() {
  # Create tmux session for a named slot if missing. Wraps the command in a
  # respawn loop so Claude exit → relaunch without daemon babysitting.
  local slot_name="$1"
  local cmd="$2"
  local session
  session=$(slot_session_name "$slot_name")

  if tmux has-session -t "$session" 2>/dev/null; then
    return 1
  fi

  # The respawn loop runs inside tmux's shell-command. `sleep 2` prevents a
  # runaway loop if the CLI crashes immediately; user can still ctrl-c the
  # inner process and get a fresh one.
  tmux new-session -d -s "$session" "while :; do ${cmd}; sleep 2; done"
  tmux set-option -t "$session" status off 2>/dev/null || true
  log "Hold session up: $session ($cmd)"

  _attach_log_filter "$session" "$slot_name"
  [[ -n "$PRIMER_LOG_FILTER" ]] && _announce_debug_mode "$session" "$slot_name"

  set_state "$slot_name" "held"
  return 0
}

start_hold_daemon() {
  require tmux
  mkdir -p "$PRIMER_DIR" "$PRIMER_STATE_DIR"

  if [[ ${#SLOT_COMMANDS[@]} -eq 0 ]]; then
    # Hold mode without PRIMER_SLOTS: spawn N copies of PRIMER_CLI.
    local n=0
    while [[ $n -lt $PRIMER_POOL_SIZE ]]; do
      SLOT_COMMANDS+=("$PRIMER_CLI")
      local name="Claude"
      [[ $n -gt 0 ]] && name="Claude-$((n + 1))"
      SLOT_NAMES+=("$name")
      n=$((n + 1))
    done
  fi

  log "Starting primerd in HOLD mode (${#SLOT_COMMANDS[@]} slots, filter: ${PRIMER_LOG_FILTER:-none})"
  for i in "${!SLOT_COMMANDS[@]}"; do
    log "  slot '${SLOT_NAMES[$i]}' → ${SLOT_COMMANDS[$i]}"
  done

  while true; do
    for i in "${!SLOT_COMMANDS[@]}"; do
      ensure_hold_session "${SLOT_NAMES[$i]}" "${SLOT_COMMANDS[$i]}" || true
    done
    sleep "$PRIMER_HOLD_CHECK_INTERVAL"
  done
}

# ── Warm mode (v0.1 behavior, preserved) ───────────────────────────────────

window_name() { echo "${PRIMER_SESSION_PREFIX}-$1"; }

pane_content() {
  tmux capture-pane -t "${TMUX_SESSION}:${1}" -p 2>/dev/null || echo ""
}

is_warm() {
  pane_content "$1" | grep -qF "$PRIMER_WARMUP_MARKER"
}

send_keys() {
  local window="$1"; shift
  tmux send-keys -t "${TMUX_SESSION}:${window}" -l "$*"
  sleep 0.3
  tmux send-keys -t "${TMUX_SESSION}:${window}" Enter
}

ensure_tmux_session() {
  if ! tmux has-session -t "$TMUX_SESSION" 2>/dev/null; then
    tmux new-session -d -s "$TMUX_SESSION" -n "${PRIMER_SESSION_PREFIX}-0"
    tmux set-option -t "$TMUX_SESSION" status off 2>/dev/null || true
    log "Created tmux session: $TMUX_SESSION"
  fi
}

next_slot() {
  for slot in $(seq 0 $((PRIMER_POOL_SIZE - 1))); do
    local state
    state=$(get_state "$slot")
    [[ "$state" == "unknown" || "$state" == "cold" ]] && { echo "$slot"; return 0; }
  done
  for slot in $(seq 0 $((PRIMER_POOL_SIZE - 1))); do
    [[ "$(get_state "$slot")" == "stale" ]] && { echo "$slot"; return 0; }
  done
  return 1
}

slot_color() {
  local slot="$1"
  [[ -z "$PRIMER_SLOT_COLORS" ]] && return
  IFS=',' read -r -a _colors <<< "$PRIMER_SLOT_COLORS"
  echo "${_colors[$slot]:-}"
}

spawn_window() {
  local slot="$1"
  local window
  window=$(window_name "$slot")
  if ! tmux list-windows -t "$TMUX_SESSION" -F '#{window_name}' 2>/dev/null | grep -q "^${window}$"; then
    tmux new-window -t "$TMUX_SESSION" -n "$window"
    log "Spawned window: $window"
  fi
  local color
  color=$(slot_color "$slot")
  if [[ -n "$color" ]]; then
    tmux set-window-option -t "${TMUX_SESSION}:${window}" window-style "bg=${color}" 2>/dev/null || true
  fi

  if [[ -n "$PRIMER_LOG_FILTER" ]]; then
    _attach_log_filter "${TMUX_SESSION}:${window}" "slot-${slot}"
    _announce_debug_mode "${TMUX_SESSION}:${window}" "slot-${slot}"
  fi

  set_state "$slot" "spawned"
}

warm_window() {
  local slot="$1"
  local window
  window=$(window_name "$slot")

  log "Warming slot $slot..."
  set_state "$slot" "warming"

  local content
  content=$(pane_content "$window")
  if ! echo "$content" | grep -qF "$PRIMER_WARMUP_MARKER"; then
    send_keys "$window" "$PRIMER_CLI"
    sleep "$PRIMER_CLI_READY_WAIT"
  fi

  send_keys "$window" "$PRIMER_WARMUP_MSG"

  local waited=0
  while [[ $waited -lt $PRIMER_WARMUP_TIMEOUT ]]; do
    if is_warm "$window"; then
      log "Slot $slot warm ✓"
      set_state "$slot" "warm"
      tmux clear-history -t "${TMUX_SESSION}:${window}" 2>/dev/null || true
      return 0
    fi
    sleep 2
    waited=$((waited + 2))
  done

  log "WARNING: slot $slot did not warm within ${PRIMER_WARMUP_TIMEOUT}s"
  set_state "$slot" "stale"
}

rewarm_window() {
  local slot="$1"
  local window
  window=$(window_name "$slot")

  log "Re-warming slot $slot..."
  set_state "$slot" "rewarming"

  if [[ -n "$PRIMER_RESET_CMD" ]]; then
    send_keys "$window" "$PRIMER_RESET_CMD"
    sleep 1
  else
    tmux send-keys -t "${TMUX_SESSION}:${window}" C-c
    sleep 1
    tmux send-keys -t "${TMUX_SESSION}:${window}" C-c
    sleep 1
    send_keys "$window" "$PRIMER_CLI"
    sleep "$PRIMER_CLI_READY_WAIT"
  fi

  send_keys "$window" "$PRIMER_WARMUP_MSG"

  local waited=0
  while [[ $waited -lt $PRIMER_WARMUP_TIMEOUT ]]; do
    if is_warm "$window"; then
      log "Slot $slot re-warmed ✓"
      set_state "$slot" "warm"
      return 0
    fi
    sleep 2
    waited=$((waited + 2))
  done

  log "WARNING: slot $slot did not re-warm within ${PRIMER_WARMUP_TIMEOUT}s"
  set_state "$slot" "stale"
}

watch_warm_request() {
  while true; do
    if [[ -f "$PRIMER_WARM_REQUEST" ]]; then
      rm -f "$PRIMER_WARM_REQUEST"
      log "Warm request received"
      local slot
      if slot=$(next_slot 2>/dev/null); then
        ensure_tmux_session
        spawn_window "$slot"
        warm_window "$slot" &
      else
        log "All slots already warm or warming — ignoring warm request"
      fi
    fi
    sleep 2
  done
}

watch_and_rewarm() {
  [[ -z "$PRIMER_WATCH_DIR" ]] && return
  [[ -d "$PRIMER_WATCH_DIR" ]] || return

  local last_hash=""
  while true; do
    local current_hash
    current_hash=$(find "$PRIMER_WATCH_DIR" -type f \( -name "*.md" -o -name "*.json" \) -print0 \
      | sort -z | xargs -0 stat -f "%m %N" 2>/dev/null \
      || find "$PRIMER_WATCH_DIR" -type f \( -name "*.md" -o -name "*.json" \) -print0 \
      | sort -z | xargs -0 stat -c "%Y %n" 2>/dev/null \
      || echo "0")
    current_hash=$(echo "$current_hash" | md5sum 2>/dev/null | cut -d' ' -f1 \
      || echo "$current_hash" | md5 2>/dev/null || echo "0")

    if [[ -n "$last_hash" && "$current_hash" != "$last_hash" ]]; then
      log "Config change detected — rewarming warm slots"
      for slot in $(seq 0 $((PRIMER_POOL_SIZE - 1))); do
        [[ "$(get_state "$slot")" == "warm" ]] && rewarm_window "$slot" &
      done
    fi

    last_hash="$current_hash"
    sleep "$PRIMER_WATCH_INTERVAL"
  done
}

start_warm_daemon() {
  require tmux
  require "${PRIMER_CLI%% *}"

  mkdir -p "$PRIMER_DIR" "$PRIMER_STATE_DIR"
  log "Starting primerd (pool: $PRIMER_POOL_SIZE slots, cli: $PRIMER_CLI)"

  ensure_tmux_session

  for slot in $(seq 0 $((PRIMER_POOL_SIZE - 1))); do
    set_state "$slot" "cold"
  done
  log "Lazy pool ready — warming on demand via $PRIMER_WARM_REQUEST"

  watch_warm_request &
  watch_and_rewarm &

  wait
}

# ── Status reporting ───────────────────────────────────────────────────────

status_hold() {
  echo ""
  echo "mode: hold"
  for i in "${!SLOT_NAMES[@]}"; do
    local name="${SLOT_NAMES[$i]}"
    local session
    session=$(slot_session_name "$name")
    local tag=""
    if tmux has-session -t "$session" 2>/dev/null; then
      tag="✓"
    fi
    printf "  %s: %s %s\n" "$name" "$(get_state "$name")" "$tag"
  done
}

status_warm() {
  mkdir -p "$PRIMER_STATE_DIR"
  echo ""
  echo "mode: warm"
  for slot in $(seq 0 $((PRIMER_POOL_SIZE - 1))); do
    state=$(get_state "$slot")
    warm_tag=""
    [[ "$state" == "warm" ]] && warm_tag=" ✓"
    printf "  slot %s: %s%s\n" "$slot" "$state" "$warm_tag"
  done
}

# ── Dispatch ───────────────────────────────────────────────────────────────

_parse_slots

start_daemon() {
  if [[ "$PRIMER_HOLD" == "1" ]]; then
    start_hold_daemon
  else
    start_warm_daemon
  fi
}

cmd="${1:-help}"

case "$cmd" in
  start)
    if [[ -f "$PRIMER_PID_FILE" ]] && kill -0 "$(cat "$PRIMER_PID_FILE")" 2>/dev/null; then
      echo "primerd is already running (pid $(cat "$PRIMER_PID_FILE"))"
      exit 0
    fi
    mkdir -p "$PRIMER_DIR"
    (trap '' HUP; start_daemon) </dev/null >/dev/null 2>&1 &
    daemon_pid=$!
    disown "$daemon_pid" 2>/dev/null || true
    echo "$daemon_pid" > "$PRIMER_PID_FILE"
    mode="warm"
    [[ "$PRIMER_HOLD" == "1" ]] && mode="hold"
    echo "primerd started (pid $daemon_pid, mode: $mode)"
    ;;
  stop)
    if [[ -f "$PRIMER_PID_FILE" ]]; then
      kill "$(cat "$PRIMER_PID_FILE")" 2>/dev/null && echo "primerd stopped" || echo "primerd was not running"
      rm -f "$PRIMER_PID_FILE"
    else
      echo "primerd is not running"
    fi
    ;;
  status)
    if [[ -f "$PRIMER_PID_FILE" ]] && kill -0 "$(cat "$PRIMER_PID_FILE")" 2>/dev/null; then
      echo "primerd: running (pid $(cat "$PRIMER_PID_FILE"))"
    else
      echo "primerd: not running"
    fi
    if [[ "$PRIMER_HOLD" == "1" ]]; then
      status_hold
    else
      status_warm
    fi
    ;;
  help|--help|-h)
    cat <<'HELP'
primerd — llm-primer daemon

Usage: primerd <start|stop|status>

Core configuration (env or ~/.llm-primer/config):
  PRIMER_CLI             CLI command (default: claude)
  PRIMER_POOL_SIZE       Pool size (default: 2, warm mode only)
  PRIMER_WATCH_DIR       Dir to rewarm on changes (warm mode only)
  PRIMER_WARMUP_MARKER   Warmth signal (default: SESSION START)
  PRIMER_WARMUP_TIMEOUT  Seconds to wait (default: 180)
  PRIMER_RESET_CMD       Soft-reset command (default: /clear)
  PRIMER_SLOT_COLORS     Comma-sep pane bg colors

Hold mode (v0.2):
  PRIMER_HOLD=1          Skip warmup; hold N live Claude sessions
  PRIMER_SLOTS           Pipe-separated command list, one per slot
                         e.g. "claude|claude --agent §sakinos|claude --agent §scribe"
                         Slot names are derived from the --agent flag.

Log filter (v0.2):
  PRIMER_LOG_FILTER      Command to pipe pane output through. Off by default.
                         When set, Claude is told to announce DEBUG MODE on first
                         response so the user always knows logging is active.
                         Log files land in ~/.llm-primer/logs/<slot>.log.

See README.md for full details.
HELP
    ;;
  *)
    echo "Unknown command: $cmd. Run 'primerd help' for usage."
    exit 1
    ;;
esac

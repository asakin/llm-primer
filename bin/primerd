#!/usr/bin/env bash
# primerd — llm-primer daemon
#
# Manages a pool of pre-warmed LLM CLI sessions in tmux.
# Works with any CLI tool: claude, aider, ollama, llm, gemini, etc.
#
# Configuration (in priority order):
#   1. Environment variables (PRIMER_*)
#   2. Config file: ~/.llm-primer/config (or $PRIMER_CONFIG)
#   3. Built-in defaults
#
# Two pool modes:
#   lazy (default)  Pool starts cold. Sessions warm on demand via a signal file.
#                   Zero idle cost. Signal by: PostCompact hook, your LLM wiki
#                   instruction, or `primer warm`.
#   eager           Always keeps PRIMER_POOL_SIZE sessions warm.

set -euo pipefail

# Ensure Homebrew paths are visible when invoked from GUI contexts (e.g. Obsidian
# terminal plugins, launchd) whose PATH doesn't inherit shell-rc additions.
for _p in /opt/homebrew/bin /usr/local/bin; do
  [[ ":$PATH:" != *":$_p:"* ]] && [[ -d "$_p" ]] && PATH="$_p:$PATH"
done
unset _p

# ── config file loading ───────────────────────────────────────────────────────
#
# Config file is a plain KEY=VALUE file — no bash syntax, no quoting required.
# Generated by your LLM wiki assistant or written manually.
# Example location: ~/.llm-primer/config
#
# Safe to source: only KEY=VALUE lines are applied; comments and blanks ignored.

PRIMER_CONFIG="${PRIMER_CONFIG:-$HOME/.llm-primer/config}"

_load_config() {
  [[ -f "$PRIMER_CONFIG" ]] || return 0
  while IFS='=' read -r key value; do
    # Skip comments and blank lines
    [[ "$key" =~ ^[[:space:]]*# ]] && continue
    [[ -z "${key// }" ]] && continue
    key="${key// /}"
    # Only set if not already in environment (env vars win)
    [[ -n "${!key+set}" ]] && continue
    export "$key"="$value"
  done < "$PRIMER_CONFIG"
}

_load_config

# ── configuration ─────────────────────────────────────────────────────────────

PRIMER_DIR="${PRIMER_DIR:-$HOME/.llm-primer}"
PRIMER_SESSION_PREFIX="${PRIMER_SESSION_PREFIX:-primer}"
PRIMER_POOL_SIZE="${PRIMER_POOL_SIZE:-3}"
PRIMER_MODE="${PRIMER_MODE:-lazy}"           # lazy | eager
PRIMER_CLI="${PRIMER_CLI:-claude}"           # CLI for all slots unless overridden

PRIMER_RESET_CMD="${PRIMER_RESET_CMD:-/clear}"   # soft-reset command; "" = kill+respawn

# The message sent to trigger the LLM's startup protocol. This runs as the
# first user turn in every warm session, so we use it to tell the LLM what
# it's running in — which makes it a better collaborator (e.g. it can suggest
# 'primer switch' proactively when context gets heavy).
_default_warmup_msg='You are running inside llm-primer, a pre-warmed session pool. Guidelines: (1) If my context approaches ~70% of your window, tell me once I can run `primer switch` in my shell to jump to a fresh session — do not repeat the reminder. (2) Suggest the alt slot if a question is quick or better suited to a cheaper/faster model. (3) `primer` commands are shell-only; never try to run them yourself. If I accidentally type one at you, briefly tell me to run it in my terminal. Now run your session start protocol.'
PRIMER_WARMUP_MSG="${PRIMER_WARMUP_MSG:-$_default_warmup_msg}"

# Override for the alt slot (falls back to PRIMER_WARMUP_MSG if unset).
# Good for telling the cheap/fast model to keep answers short.
PRIMER_ALT_WARMUP_MSG="${PRIMER_ALT_WARMUP_MSG:-}"

PRIMER_WARMUP_MARKER="${PRIMER_WARMUP_MARKER:-SESSION START}"  # string that signals warmth
PRIMER_WARMUP_TIMEOUT="${PRIMER_WARMUP_TIMEOUT:-180}"  # seconds to wait for warm marker
PRIMER_CLI_READY_WAIT="${PRIMER_CLI_READY_WAIT:-8}"  # seconds to wait for CLI TUI to be ready for input

# Per-slot pane background colors — helps distinguish slots when eyeballing tmux
# or taking screenshots. Empty = no tint. Comma-separated list, one entry per
# slot in order. Any tmux-accepted color name or #RRGGBB hex works.
PRIMER_SLOT_COLORS="${PRIMER_SLOT_COLORS:-#0d1b2a,#1b263b,#0e2a1a}"

PRIMER_WATCH_DIR="${PRIMER_WATCH_DIR:-}"        # dir to watch for config changes
PRIMER_WATCH_INTERVAL="${PRIMER_WATCH_INTERVAL:-5}"

# Alt slot — a designated slot running a different CLI (e.g. a faster/cheaper model,
# a different tool, a different context). Slot only activates when PRIMER_ALT_CLI is set.
# Leave PRIMER_ALT_CLI empty to run all slots with PRIMER_CLI (uniform pool).
PRIMER_ALT_SLOT="${PRIMER_ALT_SLOT:-}"      # which slot is the alt; default: last slot
PRIMER_ALT_CLI="${PRIMER_ALT_CLI:-}"        # CLI for the alt slot; empty = disabled

# Garbage collector
PRIMER_GC_VAULT="${PRIMER_GC_VAULT:-}"
PRIMER_GC_INTERVAL="${PRIMER_GC_INTERVAL:-21600}"   # 6 hours

PRIMER_PID_FILE="$PRIMER_DIR/primerd.pid"
PRIMER_LOG_FILE="$PRIMER_DIR/primerd.log"
PRIMER_STATE_DIR="$PRIMER_DIR/state"
PRIMER_WARM_REQUEST="$PRIMER_DIR/warm-request"
TMUX_SESSION="$PRIMER_SESSION_PREFIX-pool"

# ── logging ───────────────────────────────────────────────────────────────────

log() { echo "$(date '+%Y-%m-%d %H:%M:%S') $*" | tee -a "$PRIMER_LOG_FILE"; }
die() { log "ERROR: $*" >&2; exit 1; }
require() { command -v "$1" &>/dev/null || die "'$1' is required but not installed"; }

# ── per-slot CLI resolution ────────────────────────────────────────────────────
#
# Priority per slot N:
#   1. PRIMER_SLOT_{N}_CLI  (explicit per-slot override, highest priority)
#   2. Alt slot assignment   (PRIMER_ALT_SLOT + PRIMER_ALT_CLI)
#   3. PRIMER_CLI            (global default)

_default_alt_slot() {
  echo $(( PRIMER_POOL_SIZE - 1 ))
}

slot_cli() {
  local slot="$1"

  # Explicit per-slot override
  local var="PRIMER_SLOT_${slot}_CLI"
  if [[ -n "${!var:-}" ]]; then
    echo "${!var}"
    return
  fi

  # Alt slot (only if PRIMER_ALT_CLI is configured)
  if [[ -n "$PRIMER_ALT_CLI" ]]; then
    local alt_slot="${PRIMER_ALT_SLOT:-$(_default_alt_slot)}"
    if [[ "$slot" -eq "$alt_slot" ]]; then
      echo "$PRIMER_ALT_CLI"
      return
    fi
  fi

  echo "$PRIMER_CLI"
}

slot_label() {
  local slot="$1"
  local cli
  cli=$(slot_cli "$slot")
  # Return first meaningful word of the CLI command as the label
  echo "$cli" | awk '{print $1}' | xargs basename 2>/dev/null || echo "$cli"
}

is_alt_slot() {
  local slot="$1"
  [[ -z "$PRIMER_ALT_CLI" ]] && return 1
  local alt_slot="${PRIMER_ALT_SLOT:-$(_default_alt_slot)}"
  [[ "$slot" -eq "$alt_slot" ]]
}

slot_warmup_msg() {
  local slot="$1"
  if is_alt_slot "$slot" && [[ -n "$PRIMER_ALT_WARMUP_MSG" ]]; then
    echo "$PRIMER_ALT_WARMUP_MSG"
  else
    echo "$PRIMER_WARMUP_MSG"
  fi
}

# ── tmux helpers ──────────────────────────────────────────────────────────────

window_name() { echo "${PRIMER_SESSION_PREFIX}-$1"; }

pane_content() {
  tmux capture-pane -t "${TMUX_SESSION}:${1}" -p 2>/dev/null || echo ""
}

is_warm() {
  pane_content "$1" | grep -qF "$PRIMER_WARMUP_MARKER"
}

send_keys() {
  local window="$1"; shift
  # Type text, then submit with a brief gap so TUIs that debounce keystrokes
  # (e.g. Claude Code) actually register the Enter as submission.
  tmux send-keys -t "${TMUX_SESSION}:${window}" -l "$*"
  sleep 0.3
  tmux send-keys -t "${TMUX_SESSION}:${window}" Enter
}

# ── pool management ───────────────────────────────────────────────────────────

ensure_tmux_session() {
  if ! tmux has-session -t "$TMUX_SESSION" 2>/dev/null; then
    tmux new-session -d -s "$TMUX_SESSION" -n "${PRIMER_SESSION_PREFIX}-0"
    # Suppress tmux status bar so host TUI statuslines (e.g. Claude Code) show through.
    tmux set-option -t "$TMUX_SESSION" status off 2>/dev/null || true
    log "Created tmux session: $TMUX_SESSION"
  fi
}

next_slot() {
  for slot in $(seq 0 $((PRIMER_POOL_SIZE - 1))); do
    local state
    state=$(get_state "$slot")
    [[ "$state" == "unknown" || "$state" == "cold" ]] && { echo "$slot"; return 0; }
  done
  for slot in $(seq 0 $((PRIMER_POOL_SIZE - 1))); do
    [[ "$(get_state "$slot")" == "stale" ]] && { echo "$slot"; return 0; }
  done
  return 1
}

slot_color() {
  local slot="$1"
  [[ -z "$PRIMER_SLOT_COLORS" ]] && return
  IFS=',' read -r -a _colors <<< "$PRIMER_SLOT_COLORS"
  echo "${_colors[$slot]:-}"
}

spawn_window() {
  local slot="$1"
  local window
  window=$(window_name "$slot")
  if ! tmux list-windows -t "$TMUX_SESSION" -F '#{window_name}' 2>/dev/null | grep -q "^${window}$"; then
    tmux new-window -t "$TMUX_SESSION" -n "$window"
    log "Spawned window: $window"
  fi
  # Tint the pane background so slots are visually distinguishable when flipping
  # between them or taking screenshots.
  local color
  color=$(slot_color "$slot")
  if [[ -n "$color" ]]; then
    tmux set-window-option -t "${TMUX_SESSION}:${window}" window-style "bg=${color}" 2>/dev/null || true
  fi
  set_state "$slot" "spawned"
}

warm_window() {
  local slot="$1"
  local window
  window=$(window_name "$slot")
  local cli
  cli=$(slot_cli "$slot")

  log "Warming slot $slot ($(slot_label "$slot"))..."
  set_state "$slot" "warming"

  # Launch the CLI unless the pane already shows the warmup marker
  # (i.e. the CLI is already running from a previous warm attempt)
  local content
  content=$(pane_content "$window")
  if ! echo "$content" | grep -qF "$PRIMER_WARMUP_MARKER"; then
    send_keys "$window" "$cli"
    # Wait for the CLI TUI to finish booting before typing the preamble.
    # Claude Code in particular can take 5–15s on a cold start; if we type
    # too early the input or the trailing Enter gets dropped.
    sleep "$PRIMER_CLI_READY_WAIT"
  fi

  send_keys "$window" "$(slot_warmup_msg "$slot")"

  local waited=0
  while [[ $waited -lt $PRIMER_WARMUP_TIMEOUT ]]; do
    if is_warm "$window"; then
      log "Slot $slot warm ✓ ($(slot_label "$slot"))"
      set_state "$slot" "warm"
      set_slot_label "$slot" "$(slot_label "$slot")"
      # Drop scrollback so the user attaches into a clean pane instead of
      # scrolling through the CLI's full startup output (and any prior
      # warm attempts that left history behind).
      tmux clear-history -t "${TMUX_SESSION}:${window}" 2>/dev/null || true
      return 0
    fi
    sleep 2
    waited=$((waited + 2))
  done

  log "WARNING: slot $slot did not warm within ${PRIMER_WARMUP_TIMEOUT}s"
  set_state "$slot" "stale"
}

rewarm_window() {
  local slot="$1"
  local window
  window=$(window_name "$slot")
  local cli
  cli=$(slot_cli "$slot")

  log "Re-warming slot $slot ($(slot_label "$slot"))..."
  set_state "$slot" "rewarming"

  if [[ -n "$PRIMER_RESET_CMD" ]]; then
    send_keys "$window" "$PRIMER_RESET_CMD"
    sleep 1
  else
    log "Slot $slot: no PRIMER_RESET_CMD — using kill+respawn"
    tmux send-keys -t "${TMUX_SESSION}:${window}" C-c
    sleep 1
    tmux send-keys -t "${TMUX_SESSION}:${window}" C-c
    sleep 1
    send_keys "$window" "$cli"
    sleep "$PRIMER_CLI_READY_WAIT"
  fi

  send_keys "$window" "$(slot_warmup_msg "$slot")"

  local waited=0
  while [[ $waited -lt $PRIMER_WARMUP_TIMEOUT ]]; do
    if is_warm "$window"; then
      log "Slot $slot re-warmed ✓ ($(slot_label "$slot"))"
      set_state "$slot" "warm"
      set_slot_label "$slot" "$(slot_label "$slot")"
      return 0
    fi
    sleep 2
    waited=$((waited + 2))
  done

  log "WARNING: slot $slot did not re-warm within ${PRIMER_WARMUP_TIMEOUT}s"
  set_state "$slot" "stale"
}

# ── state tracking ─────────────────────────────────────────────────────────────

set_state()      { mkdir -p "$PRIMER_STATE_DIR"; echo "$2" > "$PRIMER_STATE_DIR/slot-${1}"; }
get_state()      { local f="$PRIMER_STATE_DIR/slot-${1}"; [[ -f "$f" ]] && cat "$f" || echo "unknown"; }
set_slot_label() { echo "$2" > "$PRIMER_STATE_DIR/slot-${1}-label"; }
get_slot_label() {
  local f="$PRIMER_STATE_DIR/slot-${1}-label"
  [[ -f "$f" ]] && cat "$f" || slot_label "$1"
}

# ── warm request watcher ──────────────────────────────────────────────────────

watch_warm_request() {
  while true; do
    # Generic warm request — warms the first cold slot
    if [[ -f "$PRIMER_WARM_REQUEST" ]]; then
      rm -f "$PRIMER_WARM_REQUEST"
      log "Warm request received"
      local slot
      if slot=$(next_slot 2>/dev/null); then
        ensure_tmux_session
        spawn_window "$slot"
        warm_window "$slot" &
      else
        log "All slots already warm or warming — ignoring warm request"
      fi
    fi

    # Slot-targeted warm requests: warm-request-N warms slot N specifically.
    # Used by `primer alt` to warm the alt slot on demand.
    for req in "$PRIMER_DIR"/warm-request-*; do
      [[ -f "$req" ]] || continue
      local target_slot="${req##*/warm-request-}"
      rm -f "$req"
      if ! [[ "$target_slot" =~ ^[0-9]+$ ]] || [[ "$target_slot" -ge "$PRIMER_POOL_SIZE" ]]; then
        log "Ignoring invalid warm-request-$target_slot"
        continue
      fi
      local state
      state=$(get_state "$target_slot")
      if [[ "$state" == "warm" || "$state" == "warming" ]]; then
        log "Slot $target_slot already warm/warming — ignoring targeted request"
        continue
      fi
      log "Targeted warm request for slot $target_slot"
      ensure_tmux_session
      spawn_window "$target_slot"
      warm_window "$target_slot" &
    done

    sleep 2
  done
}

# ── config file watcher ───────────────────────────────────────────────────────

watch_and_rewarm() {
  [[ -z "$PRIMER_WATCH_DIR" ]] && return
  [[ -d "$PRIMER_WATCH_DIR" ]] || return

  local last_hash=""
  while true; do
    local current_hash
    current_hash=$(find "$PRIMER_WATCH_DIR" -type f \( -name "*.md" -o -name "*.json" \) -print0 \
      | sort -z | xargs -0 stat -f "%m %N" 2>/dev/null \
      || find "$PRIMER_WATCH_DIR" -type f \( -name "*.md" -o -name "*.json" \) -print0 \
      | sort -z | xargs -0 stat -c "%Y %n" 2>/dev/null \
      || echo "0")
    current_hash=$(echo "$current_hash" | md5sum 2>/dev/null | cut -d' ' -f1 \
      || echo "$current_hash" | md5 2>/dev/null || echo "0")

    if [[ -n "$last_hash" && "$current_hash" != "$last_hash" ]]; then
      log "Config change detected — rewarming warm slots"
      for slot in $(seq 0 $((PRIMER_POOL_SIZE - 1))); do
        [[ "$(get_state "$slot")" == "warm" ]] && rewarm_window "$slot" &
      done
    fi

    last_hash="$current_hash"
    sleep "$PRIMER_WATCH_INTERVAL"
  done
}

# ── garbage collector cron ────────────────────────────────────────────────────

run_gc_loop() {
  [[ -z "$PRIMER_GC_VAULT" ]] && return
  local gc_bin
  gc_bin=$(dirname "$(command -v primerd 2>/dev/null || echo "$0")")/primer-gc
  if [[ ! -x "$gc_bin" ]]; then
    log "GC: primer-gc not found at $gc_bin — skipping GC loop"
    return
  fi
  log "GC: loop started (vault: $PRIMER_GC_VAULT, interval: ${PRIMER_GC_INTERVAL}s)"
  while true; do
    sleep "$PRIMER_GC_INTERVAL"
    log "GC: running primer-gc on $PRIMER_GC_VAULT"
    "$gc_bin" --vault "$PRIMER_GC_VAULT" --auto >> "$PRIMER_LOG_FILE" 2>&1 || true
  done
}

# ── main loop ─────────────────────────────────────────────────────────────────

start_daemon() {
  require tmux
  require "${PRIMER_CLI%% *}"  # check the base command, not flags

  mkdir -p "$PRIMER_DIR" "$PRIMER_STATE_DIR"
  local alt_slot="${PRIMER_ALT_SLOT:-$(_default_alt_slot)}"
  local alt_info=""
  [[ -n "$PRIMER_ALT_CLI" ]] && alt_info=", alt slot: $alt_slot ($(slot_label "$alt_slot"))"
  log "Starting primerd (mode: $PRIMER_MODE, pool: $PRIMER_POOL_SIZE slots${alt_info})"

  ensure_tmux_session

  if [[ "$PRIMER_MODE" == "eager" ]]; then
    log "Eager mode: pre-warming $PRIMER_POOL_SIZE slots"
    for slot in $(seq 0 $((PRIMER_POOL_SIZE - 1))); do
      spawn_window "$slot"
      warm_window "$slot" &
    done
    wait
  else
    log "Lazy mode: pool is cold — warming on demand via $PRIMER_WARM_REQUEST"
    for slot in $(seq 0 $((PRIMER_POOL_SIZE - 1))); do
      set_state "$slot" "cold"
    done
  fi

  watch_warm_request &
  watch_and_rewarm &
  run_gc_loop &

  while true; do
    if [[ "$PRIMER_MODE" == "eager" ]]; then
      for slot in $(seq 0 $((PRIMER_POOL_SIZE - 1))); do
        local state
        state=$(get_state "$slot")
        if [[ "$state" == "stale" ]] || { [[ "$state" == "warm" ]] && ! is_warm "$(window_name "$slot")"; }; then
          [[ "$state" != "rewarming" && "$state" != "warming" ]] && rewarm_window "$slot" &
        fi
      done
    fi
    sleep 10
  done
}

# ── entry point ───────────────────────────────────────────────────────────────

cmd="${1:-help}"

case "$cmd" in
  start)
    if [[ -f "$PRIMER_PID_FILE" ]] && kill -0 "$(cat "$PRIMER_PID_FILE")" 2>/dev/null; then
      echo "primerd is already running (pid $(cat "$PRIMER_PID_FILE"))"
      exit 0
    fi
    mkdir -p "$PRIMER_DIR"
    start_daemon &
    echo $! > "$PRIMER_PID_FILE"
    echo "primerd started in $PRIMER_MODE mode (pid $(cat "$PRIMER_PID_FILE"))"
    ;;
  stop)
    if [[ -f "$PRIMER_PID_FILE" ]]; then
      kill "$(cat "$PRIMER_PID_FILE")" 2>/dev/null && echo "primerd stopped" || echo "primerd was not running"
      rm -f "$PRIMER_PID_FILE"
    else
      echo "primerd is not running"
    fi
    ;;
  status)
    if [[ -f "$PRIMER_PID_FILE" ]] && kill -0 "$(cat "$PRIMER_PID_FILE")" 2>/dev/null; then
      echo "primerd: running (mode: $PRIMER_MODE, pid $(cat "$PRIMER_PID_FILE"))"
    else
      echo "primerd: not running"
    fi
    mkdir -p "$PRIMER_STATE_DIR"
    echo ""
    for slot in $(seq 0 $((PRIMER_POOL_SIZE - 1))); do
      _st_state=$(get_state "$slot")
      _st_label=$(get_slot_label "$slot")
      _st_alt_tag=""
      _st_warm_tag=""
      is_alt_slot "$slot" && _st_alt_tag=" [alt]"
      [[ "$_st_state" == "warm" ]] && _st_warm_tag=" ✓"
      printf "  slot %s [%s]%s: %s%s\n" "$slot" "$_st_label" "$_st_alt_tag" "$_st_state" "$_st_warm_tag"
    done
    ;;
  help|--help|-h)
    cat <<'HELP'
primerd — llm-primer daemon

Usage: primerd <command>

Commands:
  start    Start the daemon
  stop     Stop the daemon
  status   Show daemon and pool status

Modes:
  lazy (default)   Pool starts cold. Warms on demand via ~/.llm-primer/warm-request.
                   Zero idle cost. Triggered by any process touching that file.

  eager            Always keeps PRIMER_POOL_SIZE sessions warm. Set PRIMER_MODE=eager.

Configuration:
  Read from environment variables, then ~/.llm-primer/config, then built-in defaults.
  Environment variables always win over the config file.

  Run: primerd config-template > ~/.llm-primer/config   to generate a starter config.

Key variables:
  PRIMER_CLI              CLI command for all slots (default: claude)
  PRIMER_POOL_SIZE        Number of pool slots (default: 3)
  PRIMER_MODE             lazy | eager (default: lazy)
  PRIMER_ALT_CLI          CLI for the alt slot (empty = disabled; set to enable)
  PRIMER_ALT_SLOT         Which slot is the alt (default: last slot)
  PRIMER_SLOT_{N}_CLI     Per-slot override (highest priority)
  PRIMER_RESET_CMD        Soft-reset command (default: /clear). "" = kill+respawn.
  PRIMER_WARMUP_MSG       Message to send to trigger session init (default: ready)
  PRIMER_WARMUP_MARKER    String to watch for in output (default: SESSION START)
  PRIMER_WARMUP_TIMEOUT   Seconds to wait for warmup (default: 180)
  PRIMER_SLOT_COLORS      Comma-sep tmux bg colors per slot (default: #0d1b2a,#1b263b,#0e2a1a)
  PRIMER_WATCH_DIR        Dir to watch for config changes (triggers rewarm)
  PRIMER_GC_VAULT         Vault path for garbage collector (empty = disabled)
  PRIMER_GC_INTERVAL      Seconds between GC runs (default: 3600)

Full config reference: https://github.com/asakin/llm-primer#configuration
HELP
    ;;
  _slot-cli)
    # Hidden helper — used by the selftest to verify slot CLI resolution.
    # Not in `primerd help`.
    slot_cli "${2:-0}"
    ;;
  config-template)
    cat <<'TEMPLATE'
# ~/.llm-primer/config
# llm-primer configuration file
# Generated by: primerd config-template
#
# Syntax: KEY=value (no quotes, no bash syntax, comments with #)
# Environment variables override values here.
# Edit this file directly or have your LLM assistant generate it.

# ── CLI ───────────────────────────────────────────────────────────────────────
# The command to launch your primary LLM session.
# Examples:
#   claude                                   (Claude Code, default)
#   aider --model gpt-4o                     (Aider with OpenAI)
#   ollama run llama3.2                      (Ollama local model)
#   llm chat                                 (Simon Willison's llm CLI)
#   gemini                                   (Gemini CLI)
PRIMER_CLI=claude

# ── pool ──────────────────────────────────────────────────────────────────────
PRIMER_MODE=lazy
PRIMER_POOL_SIZE=3

# ── alt slot ─────────────────────────────────────────────────────────────────
# A designated slot running a different CLI — a faster/cheaper model, a
# different tool, or a different context. Leave PRIMER_ALT_CLI empty to run
# all slots with PRIMER_CLI (uniform pool).
#
# Examples:
#   Claude Haiku (fast + cheap):
#     PRIMER_ALT_CLI=claude --model claude-haiku-4-5-20251001
#
#   Local Ollama model (free, offline):
#     PRIMER_ALT_CLI=ollama run llama3.2:1b
#
#   Aider with a cheaper model:
#     PRIMER_ALT_CLI=aider --model gpt-4o-mini
#
#   A completely different tool:
#     PRIMER_ALT_CLI=gemini
#
PRIMER_ALT_CLI=
# PRIMER_ALT_SLOT=2   # which slot (default: last slot in pool)

# ── warmup message ────────────────────────────────────────────────────────────
# The first user turn sent to the LLM when warming a slot. The default tells
# the LLM it's running under llm-primer so it can suggest `primer switch` when
# context gets heavy. Override if your CLI expects a specific trigger phrase.
#
# PRIMER_WARMUP_MSG=Hi — you're running inside llm-primer...
#
# Optional override just for the alt slot. Useful for cheap/fast models:
# PRIMER_ALT_WARMUP_MSG=Hi — you're the alt slot (cheap/fast model). Keep answers short unless asked otherwise. Please run your session start protocol.

# ── warmup detection ──────────────────────────────────────────────────────────
# PRIMER_WARMUP_MARKER=SESSION START
# PRIMER_WARMUP_TIMEOUT=180

# If your LLM CLI has no soft-reset command, set this to empty:
# PRIMER_RESET_CMD=

# ── watch dir ─────────────────────────────────────────────────────────────────
# When any file in this directory changes, primerd rewarns all warm slots.

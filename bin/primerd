#!/usr/bin/env bash
# primerd — llm-primer daemon
# Manages pre-warmed Claude Code sessions in tmux.
#
# Two modes:
#   lazy (default) — pool starts empty. Sessions warm on demand when Claude
#                    signals via ~/.llm-primer/warm-request (PostCompact hook,
#                    CLAUDE.md instruction, or `primer warm`). Zero idle cost.
#   eager           — always keeps PRIMER_POOL_SIZE sessions warm. Set
#                    PRIMER_MODE=eager to opt in.
#
# Pool layout (default, pool size 3):
#   slot 0  — primary session (claude)
#   slot 1  — standby session (claude)
#   slot 2  — haiku slot (claude --model claude-haiku-4-5-20251001)
#
# Override any slot's CLI with PRIMER_SLOT_{N}_CLI env var.

set -euo pipefail

PRIMER_DIR="${PRIMER_DIR:-$HOME/.llm-primer}"
PRIMER_SESSION_PREFIX="${PRIMER_SESSION_PREFIX:-primer}"
PRIMER_POOL_SIZE="${PRIMER_POOL_SIZE:-3}"
PRIMER_MODE="${PRIMER_MODE:-lazy}"        # lazy | eager
PRIMER_CLI="${PRIMER_CLI:-claude}"        # default CLI for all slots
PRIMER_RESET_CMD="${PRIMER_RESET_CMD:-/clear}"  # command to reset session context; set to "" to kill+respawn instead
PRIMER_WARMUP_MSG="${PRIMER_WARMUP_MSG:-ready}"
PRIMER_WARMUP_MARKER="${PRIMER_WARMUP_MARKER:-SESSION START}"
PRIMER_WARMUP_TIMEOUT="${PRIMER_WARMUP_TIMEOUT:-60}"
PRIMER_WATCH_INTERVAL="${PRIMER_WATCH_INTERVAL:-5}"
PRIMER_PID_FILE="$PRIMER_DIR/primerd.pid"
PRIMER_LOG_FILE="$PRIMER_DIR/primerd.log"
PRIMER_STATE_DIR="$PRIMER_DIR/state"
PRIMER_WARM_REQUEST="$PRIMER_DIR/warm-request"  # touch this to trigger lazy warm

# Haiku slot — which pool slot runs the cheap model.
# Default: last slot (PRIMER_POOL_SIZE - 1).
# Set to -1 to disable. Override with PRIMER_HAIKU_SLOT env var.
PRIMER_HAIKU_SLOT="${PRIMER_HAIKU_SLOT:-}"
PRIMER_HAIKU_CLI="${PRIMER_HAIKU_CLI:-claude --model claude-haiku-4-5-20251001}"

# Garbage collector — run primer-gc on a cron inside primerd.
# Set PRIMER_GC_VAULT to your vault path to enable. Leave empty to disable.
PRIMER_GC_VAULT="${PRIMER_GC_VAULT:-}"
PRIMER_GC_INTERVAL="${PRIMER_GC_INTERVAL:-3600}"  # seconds between GC runs (default: 1h)

# Directory to watch for config changes (triggers /clear + rewarm)
PRIMER_WATCH_DIR="${PRIMER_WATCH_DIR:-}"

# The tmux session that holds the pool
TMUX_SESSION="$PRIMER_SESSION_PREFIX-pool"

log() {
  echo "$(date '+%Y-%m-%d %H:%M:%S') $*" | tee -a "$PRIMER_LOG_FILE"
}

die() {
  log "ERROR: $*" >&2
  exit 1
}

require() {
  command -v "$1" &>/dev/null || die "'$1' is required but not installed"
}

# ── per-slot CLI resolution ────────────────────────────────────────────────────
#
# Resolution order for a given slot N:
#   1. PRIMER_SLOT_{N}_CLI env var (explicit per-slot override)
#   2. Haiku slot assignment (PRIMER_HAIKU_SLOT)
#   3. PRIMER_CLI (global default)

_default_haiku_slot() {
  echo $(( PRIMER_POOL_SIZE - 1 ))
}

slot_cli() {
  local slot="$1"

  # Explicit per-slot override takes priority
  local var="PRIMER_SLOT_${slot}_CLI"
  if [[ -n "${!var:-}" ]]; then
    echo "${!var}"
    return
  fi

  # Haiku slot assignment
  local haiku_slot="${PRIMER_HAIKU_SLOT:-$(_default_haiku_slot)}"
  if [[ "$slot" -eq "$haiku_slot" ]] && [[ "$haiku_slot" -ne -1 ]]; then
    echo "$PRIMER_HAIKU_CLI"
    return
  fi

  echo "$PRIMER_CLI"
}

slot_model_label() {
  local slot="$1"
  local cli
  cli=$(slot_cli "$slot")
  if echo "$cli" | grep -q "haiku"; then
    echo "haiku"
  elif echo "$cli" | grep -q "opus"; then
    echo "opus"
  else
    echo "claude"
  fi
}

# ── tmux helpers ──────────────────────────────────────────────────────────────

window_name() {
  echo "${PRIMER_SESSION_PREFIX}-$1"
}

pane_content() {
  local window="$1"
  tmux capture-pane -t "${TMUX_SESSION}:${window}" -p 2>/dev/null || echo ""
}

is_warm() {
  local window="$1"
  pane_content "$window" | grep -qF "$PRIMER_WARMUP_MARKER"
}

send_keys() {
  local window="$1"
  shift
  tmux send-keys -t "${TMUX_SESSION}:${window}" "$*" Enter
}

# ── pool management ───────────────────────────────────────────────────────────

ensure_tmux_session() {
  if ! tmux has-session -t "$TMUX_SESSION" 2>/dev/null; then
    tmux new-session -d -s "$TMUX_SESSION" -n "${PRIMER_SESSION_PREFIX}-0"
    log "Created tmux session: $TMUX_SESSION"
  fi
}

# Returns the index of the next unused slot (creating it if needed), or exits 1 if pool is full
next_slot() {
  for slot in $(seq 0 $((PRIMER_POOL_SIZE - 1))); do
    local state
    state=$(get_state "$slot")
    if [[ "$state" == "unknown" || "$state" == "cold" ]]; then
      echo "$slot"
      return 0
    fi
  done
  # All slots occupied — find the oldest stale one
  for slot in $(seq 0 $((PRIMER_POOL_SIZE - 1))); do
    local state
    state=$(get_state "$slot")
    if [[ "$state" == "stale" ]]; then
      echo "$slot"
      return 0
    fi
  done
  return 1
}

spawn_window() {
  local slot="$1"
  local window
  window=$(window_name "$slot")

  if ! tmux list-windows -t "$TMUX_SESSION" -F '#{window_name}' 2>/dev/null | grep -q "^${window}$"; then
    tmux new-window -t "$TMUX_SESSION" -n "$window"
    log "Spawned window: $window"
  fi

  set_state "$slot" "spawned"
}

warm_window() {
  local slot="$1"
  local window
  window=$(window_name "$slot")
  local cli
  cli=$(slot_cli "$slot")

  log "Warming slot $slot (cli: $cli)..."
  set_state "$slot" "warming"

  local content
  content=$(pane_content "$window")
  if ! echo "$content" | grep -qF "$PRIMER_WARMUP_MARKER" && ! echo "$content" | grep -q '\$'; then
    send_keys "$window" "$cli"
  fi

  sleep 2
  send_keys "$window" "$PRIMER_WARMUP_MSG"

  local waited=0
  while [[ $waited -lt $PRIMER_WARMUP_TIMEOUT ]]; do
    if is_warm "$window"; then
      log "Slot $slot is warm ✓ ($(slot_model_label "$slot"))"
      set_state "$slot" "warm"
      set_model "$slot" "$(slot_model_label "$slot")"
      return 0
    fi
    sleep 2
    waited=$((waited + 2))
  done

  log "WARNING: slot $slot did not warm within ${PRIMER_WARMUP_TIMEOUT}s"
  set_state "$slot" "stale"
}

rewarm_window() {
  local slot="$1"
  local window
  window=$(window_name "$slot")
  local cli
  cli=$(slot_cli "$slot")

  log "Re-warming slot $slot (cli: $cli)..."
  set_state "$slot" "rewarming"

  if [[ -n "$PRIMER_RESET_CMD" ]]; then
    # Soft reset — send the reset command (e.g. /clear for Claude Code)
    send_keys "$window" "$PRIMER_RESET_CMD"
    sleep 1
  else
    # Hard reset — kill current process and respawn the CLI
    log "Slot $slot: no PRIMER_RESET_CMD set, using kill+respawn"
    tmux send-keys -t "${TMUX_SESSION}:${window}" C-c
    sleep 1
    tmux send-keys -t "${TMUX_SESSION}:${window}" C-c
    sleep 1
    send_keys "$window" "$cli"
    sleep 2
  fi

  send_keys "$window" "$PRIMER_WARMUP_MSG"

  local waited=0
  while [[ $waited -lt $PRIMER_WARMUP_TIMEOUT ]]; do
    if is_warm "$window"; then
      log "Slot $slot re-warmed ✓ ($(slot_model_label "$slot"))"
      set_state "$slot" "warm"
      set_model "$slot" "$(slot_model_label "$slot")"
      return 0
    fi
    sleep 2
    waited=$((waited + 2))
  done

  log "WARNING: slot $slot did not re-warm within ${PRIMER_WARMUP_TIMEOUT}s"
  set_state "$slot" "stale"
}

# ── state tracking ─────────────────────────────────────────────────────────────

set_state() {
  local slot="$1"
  local state="$2"
  mkdir -p "$PRIMER_STATE_DIR"
  echo "$state" > "$PRIMER_STATE_DIR/slot-${slot}"
}

get_state() {
  local slot="$1"
  local file="$PRIMER_STATE_DIR/slot-${slot}"
  [[ -f "$file" ]] && cat "$file" || echo "unknown"
}

set_model() {
  local slot="$1"
  local model="$2"
  echo "$model" > "$PRIMER_STATE_DIR/slot-${slot}-model"
}

get_model() {
  local slot="$1"
  local file="$PRIMER_STATE_DIR/slot-${slot}-model"
  [[ -f "$file" ]] && cat "$file" || slot_model_label "$slot"
}

# ── lazy warm trigger ─────────────────────────────────────────────────────────
#
# Any process can request a warm session by touching ~/.llm-primer/warm-request.
# Intended callers:
#   - Claude Code PostCompact hook (context just got heavy → warm a replacement)
#   - CLAUDE.md instruction (Claude decides context is long → signals itself)
#   - `primer warm` / `primer switch` CLI commands
#   - Any script

watch_warm_request() {
  while true; do
    if [[ -f "$PRIMER_WARM_REQUEST" ]]; then
      rm -f "$PRIMER_WARM_REQUEST"
      log "Warm request received"

      local slot
      if slot=$(next_slot 2>/dev/null); then
        ensure_tmux_session
        spawn_window "$slot"
        warm_window "$slot" &
      else
        log "All slots already warm or warming — ignoring warm request"
      fi
    fi
    sleep 2
  done
}

# ── config file watcher ───────────────────────────────────────────────────────

watch_and_rewarm() {
  [[ -z "$PRIMER_WATCH_DIR" ]] && return
  [[ -d "$PRIMER_WATCH_DIR" ]] || return

  local last_hash=""

  while true; do
    local current_hash
    current_hash=$(find "$PRIMER_WATCH_DIR" -type f \( -name "*.md" -o -name "*.json" \) -print0 \
      | sort -z | xargs -0 stat -f "%m %N" 2>/dev/null \
      || find "$PRIMER_WATCH_DIR" -type f \( -name "*.md" -o -name "*.json" \) -print0 \
      | sort -z | xargs -0 stat -c "%Y %n" 2>/dev/null \
      || echo "0")
    current_hash=$(echo "$current_hash" | md5sum 2>/dev/null | cut -d' ' -f1 \
      || echo "$current_hash" | md5 2>/dev/null \
      || echo "0")

    if [[ -n "$last_hash" && "$current_hash" != "$last_hash" ]]; then
      log "Config change detected in $PRIMER_WATCH_DIR — rewarming all warm slots"
      for slot in $(seq 0 $((PRIMER_POOL_SIZE - 1))); do
        local state
        state=$(get_state "$slot")
        if [[ "$state" == "warm" ]]; then
          rewarm_window "$slot" &
        fi
      done
    fi

    last_hash="$current_hash"
    sleep "$PRIMER_WATCH_INTERVAL"
  done
}

# ── garbage collector cron ────────────────────────────────────────────────────
#
# When PRIMER_GC_VAULT is set, primerd runs primer-gc periodically to move
# stray files into _inbox/ and flag formatting issues before they cause drift.

run_gc_loop() {
  [[ -z "$PRIMER_GC_VAULT" ]] && return

  # Locate primer-gc
  local gc_bin
  gc_bin=$(dirname "$(command -v primerd 2>/dev/null || echo "$0")")/primer-gc
  if [[ ! -x "$gc_bin" ]]; then
    log "GC: primer-gc not found at $gc_bin — skipping GC loop"
    return
  fi

  log "GC: loop started (vault: $PRIMER_GC_VAULT, interval: ${PRIMER_GC_INTERVAL}s)"
  while true; do
    sleep "$PRIMER_GC_INTERVAL"
    log "GC: running primer-gc on $PRIMER_GC_VAULT"
    "$gc_bin" --vault "$PRIMER_GC_VAULT" --auto >> "$PRIMER_LOG_FILE" 2>&1 || true
  done
}

# ── main loop ─────────────────────────────────────────────────────────────────

start_daemon() {
  require tmux
  require "$PRIMER_CLI"

  mkdir -p "$PRIMER_DIR" "$PRIMER_STATE_DIR"
  local haiku_slot="${PRIMER_HAIKU_SLOT:-$(_default_haiku_slot)}"
  log "Starting primerd (mode: $PRIMER_MODE, pool: $PRIMER_POOL_SIZE slots, haiku slot: $haiku_slot)"

  ensure_tmux_session

  if [[ "$PRIMER_MODE" == "eager" ]]; then
    log "Eager mode: pre-warming $PRIMER_POOL_SIZE slots"
    for slot in $(seq 0 $((PRIMER_POOL_SIZE - 1))); do
      spawn_window "$slot"
      warm_window "$slot" &
    done
    wait
  else
    log "Lazy mode: pool is cold — warming on demand via $PRIMER_WARM_REQUEST"
    for slot in $(seq 0 $((PRIMER_POOL_SIZE - 1))); do
      set_state "$slot" "cold"
    done
  fi

  # Warm request watcher (lazy mode signal handler — runs in both modes)
  watch_warm_request &

  # Config file watcher
  watch_and_rewarm &

  # Garbage collector cron (only when PRIMER_GC_VAULT is set)
  run_gc_loop &

  # Health loop (eager mode: re-warm stale slots; lazy mode: no-op unless slots were warmed)
  while true; do
    if [[ "$PRIMER_MODE" == "eager" ]]; then
      for slot in $(seq 0 $((PRIMER_POOL_SIZE - 1))); do
        state=$(get_state "$slot")
        if [[ "$state" == "stale" ]] || { [[ "$state" == "warm" ]] && ! is_warm "$(window_name "$slot")"; }; then
          if [[ "$state" != "rewarming" && "$state" != "warming" ]]; then
            rewarm_window "$slot" &
          fi
        fi
      done
    fi
    sleep 10
  done
}

# ── entry point ───────────────────────────────────────────────────────────────

cmd="${1:-help}"

case "$cmd" in
  start)
    if [[ -f "$PRIMER_PID_FILE" ]] && kill -0 "$(cat "$PRIMER_PID_FILE")" 2>/dev/null; then
      echo "primerd is already running (pid $(cat "$PRIMER_PID_FILE"))"
      exit 0
    fi
    mkdir -p "$PRIMER_DIR"
    start_daemon &
    echo $! > "$PRIMER_PID_FILE"
    echo "primerd started in $PRIMER_MODE mode (pid $(cat "$PRIMER_PID_FILE"))"
    ;;
  stop)
    if [[ -f "$PRIMER_PID_FILE" ]]; then
      kill "$(cat "$PRIMER_PID_FILE")" 2>/dev/null && echo "primerd stopped" || echo "primerd was not running"
      rm -f "$PRIMER_PID_FILE"
    else
      echo "primerd is not running"
    fi
    ;;
  status)
    if [[ -f "$PRIMER_PID_FILE" ]] && kill -0 "$(cat "$PRIMER_PID_FILE")" 2>/dev/null; then
      echo "primerd: running (mode: $PRIMER_MODE, pid $(cat "$PRIMER_PID_FILE"))"
    else
      echo "primerd: not running"
    fi
    mkdir -p "$PRIMER_STATE_DIR"
    local haiku_slot="${PRIMER_HAIKU_SLOT:-$(_default_haiku_slot)}"
    echo ""
    for slot in $(seq 0 $((PRIMER_POOL_SIZE - 1))); do
      state=$(get_state "$slot")
      model=$(get_model "$slot")
      warm_indicator=""
      haiku_indicator=""
      [[ "$state" == "warm" ]] && warm_indicator=" ✓"
      [[ "$slot" -eq "$haiku_slot" ]] && haiku_indicator=" [haiku]"
      printf "  slot %s [%s]%s: %s%s\n" "$slot" "$model" "$haiku_indicator" "$state" "$warm_indicator"
    done
    ;;
  help|--help|-h)
    cat <<'HELP'
primerd — llm-primer daemon

Usage: primerd <command>

Commands:
  start    Start the daemon
  stop     Stop the daemon
  status   Show daemon and pool status

Modes:
  lazy (default)   Pool starts cold. Sessions warm on demand when Claude
                   signals via ~/.llm-primer/warm-request. Zero idle token cost.
                   Triggered by: PostCompact hook, CLAUDE.md instruction, `primer warm`.

  eager            Always keeps PRIMER_POOL_SIZE sessions warm. Set PRIMER_MODE=eager.

Pool layout (default: 3 slots):
  slot 0  primary session (claude)
  slot 1  standby session (claude)
  slot 2  haiku slot (claude --model claude-haiku-4-5-20251001)

Configuration (environment variables):
  PRIMER_DIR              State directory (default: ~/.llm-primer)
  PRIMER_SESSION_PREFIX   Tmux window prefix (default: primer)
  PRIMER_POOL_SIZE        Max sessions in pool (default: 3)
  PRIMER_MODE             lazy | eager (default: lazy)
  PRIMER_CLI              Default CLI for all slots (default: claude)
  PRIMER_SLOT_{N}_CLI     Per-slot CLI override (e.g. PRIMER_SLOT_0_CLI="claude --model opus")
  PRIMER_HAIKU_SLOT       Which slot runs Haiku (default: last slot). Set to -1 to disable.
  PRIMER_HAIKU_CLI        Haiku slot CLI (default: claude --model claude-haiku-4-5-20251001)
  PRIMER_RESET_CMD        Command to reset session context (default: /clear for Claude Code)
                          Set to "" to kill the process and respawn PRIMER_CLI instead
  PRIMER_WARMUP_MSG       Message sent to trigger session protocol (default: ready)
  PRIMER_WARMUP_MARKER    String to watch for in output (default: SESSION START)
  PRIMER_WARMUP_TIMEOUT   Seconds to wait for warmup marker (default: 60)
  PRIMER_WATCH_DIR        Config dir to watch for changes (triggers rewarm)
  PRIMER_WATCH_INTERVAL   Seconds between watch checks (default: 5)
  PRIMER_GC_VAULT         Vault path for garbage collector (leave empty to disable)
  PRIMER_GC_INTERVAL      Seconds between GC runs (default: 3600)

Lazy mode setup (recommended):
  Add to Claude Code settings.json:

    "hooks": {
      "PostCompact": [{"hooks": [{"type": "command",
        "command": "touch ~/.llm-primer/warm-request"}]}]
    }

  Or add to CLAUDE.md:
    When your context is getting long (above ~70%), ask the user if they'd like
    to switch to a fresh session. If yes, run: touch ~/.llm-primer/warm-request
    Then tell them to run `primer attach` in a new terminal.

HELP
    ;;
  *)
    echo "Unknown command: $cmd. Run 'primerd help' for usage."
    exit 1
    ;;
esac

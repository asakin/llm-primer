#!/usr/bin/env bash
# primer-selftest — llm-primer self-test suite
#
# Tests the daemon, CLI, config system, and garbage collector without
# touching your real pool or your actual LLM CLI.
#
# Usage:
#   primer selftest          # run all tests
#   primer selftest --fast   # skip tests that need tmux running
#   primer-selftest --help   # this help

set -euo pipefail

# ── configuration ─────────────────────────────────────────────────────────────

FAST_ONLY=false
VERBOSE=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --fast)   FAST_ONLY=true; shift ;;
    --verbose|-v) VERBOSE=true; shift ;;
    --help|-h)
      cat <<'HELP'
primer-selftest — llm-primer self-test suite

Tests the daemon, CLI, config system, and GC without touching your real pool
or making any LLM API calls. Uses a fake CLI that echoes SESSION START.

Usage:
  primer selftest            Run all tests
  primer selftest --fast     Skip tests that spawn tmux sessions (faster)
  primer selftest --verbose  Print each check as it runs

Exit codes:
  0   All tests passed
  1   One or more tests failed

Tests:
  config    Config file loading (KEY=VALUE parsing, env var override)
  pool      Pool lifecycle: start, warm, status, stop
  alt       Alt slot CLI resolution and label
  switch    primer switch creates warm-request file
  gc        Garbage collector: stray detection, frontmatter lint, duplicate slugs
  install   install.sh dry-run check (curl not called)
HELP
      exit 0
      ;;
    *) echo "Unknown option: $1. Run 'primer-selftest --help'." >&2; exit 1 ;;
  esac
done

# ── test harness ──────────────────────────────────────────────────────────────

PASS=0
FAIL=0
SKIP=0
_failures=()

_pass() { PASS=$((PASS + 1)); $VERBOSE && echo "  ✓ $1"; return 0; }
_fail() { FAIL=$((FAIL + 1)); _failures+=("$1"); echo "  ✗ $1"; return 1; }
_skip() { SKIP=$((SKIP + 1)); $VERBOSE && echo "  ⊘ $1 (skipped)"; return 0; }

assert_eq() {
  local desc="$1" expected="$2" actual="$3"
  if [[ "$expected" == "$actual" ]]; then
    _pass "$desc"
  else
    _fail "$desc (expected: '$expected', got: '$actual')"
  fi
}

assert_contains() {
  local desc="$1" needle="$2" haystack="$3"
  if [[ "$haystack" == *"$needle"* ]]; then
    _pass "$desc"
  else
    _fail "$desc (expected to contain: '$needle')"
  fi
}

assert_file_exists() {
  local desc="$1" file="$2"
  [[ -f "$file" ]] && _pass "$desc" || _fail "$desc (file not found: $file)"
}

assert_file_missing() {
  local desc="$1" file="$2"
  [[ ! -f "$file" ]] && _pass "$desc" || _fail "$desc (file should not exist: $file)"
}

assert_exit() {
  local desc="$1" expected_code="$2"
  shift 2
  local actual_code=0
  "$@" &>/dev/null || actual_code=$?
  assert_eq "$desc" "$expected_code" "$actual_code"
}

section() { echo ""; echo "── $1 ──"; }

# ── test environment ──────────────────────────────────────────────────────────

TEST_DIR=$(mktemp -d)
trap 'rm -rf "$TEST_DIR"' EXIT

export PRIMER_DIR="$TEST_DIR/primer"
export PRIMER_CONFIG="$TEST_DIR/primer.conf"
export PRIMER_SESSION_PREFIX="selftest"
export PRIMER_POOL_SIZE=3
export PRIMER_CLI="echo"           # fake CLI that exits immediately
export PRIMER_WARMUP_MARKER="SESSION START"
export PRIMER_WARMUP_MSG="ready"

# Locate the scripts being tested
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PRIMERD="$SCRIPT_DIR/primerd"
PRIMER="$SCRIPT_DIR/primer"
PRIMER_GC="$SCRIPT_DIR/primer-gc"

[[ -x "$PRIMERD" ]] || { echo "error: primerd not found at $PRIMERD" >&2; exit 1; }
[[ -x "$PRIMER"  ]] || { echo "error: primer not found at $PRIMER"   >&2; exit 1; }
[[ -x "$PRIMER_GC" ]] || { echo "error: primer-gc not found at $PRIMER_GC" >&2; exit 1; }

echo "primer-selftest"
echo "───────────────"
echo "test dir: $TEST_DIR"
echo ""

# ── test: config file ─────────────────────────────────────────────────────────

section "config"

# Write a test config
cat > "$PRIMER_CONFIG" <<'EOF'
# test config
PRIMER_POOL_SIZE=5
PRIMER_ALT_CLI=ollama run llama3
PRIMER_GC_INTERVAL=7200
EOF

# Source the config-loading logic inline (test it in isolation)
_test_load_config() {
  local key value
  while IFS='=' read -r key value; do
    [[ "$key" =~ ^[[:space:]]*# ]] && continue
    [[ -z "${key// }" ]] && continue
    key="${key// /}"
    [[ -n "${!key+set}" ]] && continue
    export "$key"="$value"
  done < "$PRIMER_CONFIG"
}

# Note: assertions inside subshells now propagate failures (_fail returns 1).
# The subshell's last exit code determines if the outer || _fail fires.

(
  unset PRIMER_POOL_SIZE PRIMER_ALT_CLI PRIMER_GC_INTERVAL 2>/dev/null || true
  _test_load_config
  assert_eq "config: PRIMER_POOL_SIZE loaded" "5" "$PRIMER_POOL_SIZE" || exit 1
  assert_eq "config: PRIMER_ALT_CLI loaded" "ollama run llama3" "$PRIMER_ALT_CLI" || exit 1
  assert_eq "config: PRIMER_GC_INTERVAL loaded" "7200" "$PRIMER_GC_INTERVAL" || exit 1
) || _fail "config: subshell assertions failed (see above)"

(
  export PRIMER_POOL_SIZE=2
  _test_load_config
  assert_eq "config: env var wins over file" "2" "$PRIMER_POOL_SIZE" || exit 1
) || _fail "config: env override subshell failed"

printf "# comment\n\nKEY=value\n" > "$TEST_DIR/clean.conf"
(
  export PRIMER_CONFIG="$TEST_DIR/clean.conf"
  _test_load_config
  assert_eq "config: comments + blanks parsed" "value" "${KEY:-}" || exit 1
) || _fail "config: comments/blanks subshell failed"

# ── test: config-template ─────────────────────────────────────────────────────

section "config-template"

output=$("$PRIMERD" config-template)
assert_contains "config-template: PRIMER_CLI present" "PRIMER_CLI=" "$output"
assert_contains "config-template: PRIMER_ALT_CLI present" "PRIMER_ALT_CLI=" "$output"
assert_contains "config-template: examples present" "ollama" "$output"
assert_contains "config-template: claude example present" "claude" "$output"
assert_contains "config-template: aider example present" "aider" "$output"

# ── test: alt slot resolution ─────────────────────────────────────────────────

section "alt slot"

# Use the hidden `primerd _slot-cli` subcommand to verify per-slot CLI resolution
# without sourcing internals (portable across bash versions).
# Env vars are set per-command so assertions run in the parent shell and count correctly.

_alt_base_env=(PRIMER_POOL_SIZE=3 PRIMER_CLI=claude PRIMER_ALT_CLI="ollama run llama3" PRIMER_ALT_SLOT=2 PRIMER_CONFIG=/dev/null)

result=$(env "${_alt_base_env[@]}" "$PRIMERD" _slot-cli 0)
assert_eq "alt: slot 0 uses PRIMER_CLI" "claude" "$result"

result=$(env "${_alt_base_env[@]}" "$PRIMERD" _slot-cli 1)
assert_eq "alt: slot 1 uses PRIMER_CLI" "claude" "$result"

result=$(env "${_alt_base_env[@]}" "$PRIMERD" _slot-cli 2)
assert_eq "alt: slot 2 uses PRIMER_ALT_CLI" "ollama run llama3" "$result"

# Per-slot override takes priority over alt assignment
result=$(env "${_alt_base_env[@]}" PRIMER_SLOT_2_CLI="aider --model gpt-4o" "$PRIMERD" _slot-cli 2)
assert_eq "alt: PRIMER_SLOT_2_CLI overrides alt" "aider --model gpt-4o" "$result"

# Empty PRIMER_ALT_CLI means uniform pool — all slots use PRIMER_CLI
result=$(env PRIMER_POOL_SIZE=3 PRIMER_CLI=claude PRIMER_ALT_CLI="" PRIMER_CONFIG=/dev/null "$PRIMERD" _slot-cli 2)
assert_eq "alt: uniform pool when PRIMER_ALT_CLI empty" "claude" "$result"

# primer alt fails helpfully when PRIMER_ALT_CLI is not set
output=$(env PRIMER_ALT_CLI="" PRIMER_CONFIG=/dev/null "$PRIMER" alt 2>&1 || true)
assert_contains "alt: helpful error when not configured" "PRIMER_ALT_CLI" "$output"

# ── test: primer switch ───────────────────────────────────────────────────────

section "switch"

mkdir -p "$PRIMER_DIR"
rm -f "$PRIMER_DIR/warm-request"

output=$("$PRIMER" switch 2>&1)
assert_file_exists "switch: warm-request file created" "$PRIMER_DIR/warm-request"
assert_contains "switch: output mentions primer attach" "primer attach" "$output"

# Cleanup
rm -f "$PRIMER_DIR/warm-request"

# ── test: primer warm ─────────────────────────────────────────────────────────

section "warm"

"$PRIMER" warm
assert_file_exists "warm: warm-request file created" "$PRIMER_DIR/warm-request"
rm -f "$PRIMER_DIR/warm-request"

# ── test: garbage collector ───────────────────────────────────────────────────

section "gc"

# Build a fake vault
VAULT="$TEST_DIR/vault"
mkdir -p \
  "$VAULT/_inbox" \
  "$VAULT/_meta/instructions" \
  "$VAULT/_config" \
  "$VAULT/1-Projects/myproject" \
  "$VAULT/2-Knowledge" \
  "$VAULT/stray-dir"

# Files that should NOT be moved
echo "---" > "$VAULT/README.md"
echo "---" > "$VAULT/_inbox/2026-04-01-note.md"
echo "---" > "$VAULT/_meta/instructions/general.md"
echo "---" > "$VAULT/_config/config.md"
echo "---" > "$VAULT/1-Projects/myproject/overview.md"

# Files that SHOULD be flagged as stray
echo "---" > "$VAULT/stray-dir/orphan.md"
echo "---" > "$VAULT/random-note.md"

# File without frontmatter in a content dir (should be flagged by lint)
echo "# No frontmatter here" > "$VAULT/1-Projects/myproject/no-frontmatter.md"

# File without frontmatter in _inbox/ (should NOT be flagged — raw captures are OK)
echo "Some raw captured note" > "$VAULT/_inbox/2026-04-14-raw-capture.md"

# Duplicate slug
echo "---" > "$VAULT/1-Projects/myproject/2026-04-01-topic.md"
echo "---" > "$VAULT/2-Knowledge/2026-04-02-topic.md"

# Dry run — should report strays but not move them (exits 2 when strays found)
output=$("$PRIMER_GC" --vault "$VAULT" 2>&1) || true
assert_contains "gc: stray file reported" "STRAY" "$output"
assert_contains "gc: orphan.md reported" "orphan.md" "$output"

# Stray files should still be in place after dry run
assert_file_exists "gc: dry run does not move files" "$VAULT/stray-dir/orphan.md"

# Auto mode — should move stray files (exits 0 when done)
"$PRIMER_GC" --vault "$VAULT" --auto > /dev/null 2>&1 || true
assert_file_missing "gc: auto moves stray to inbox" "$VAULT/stray-dir/orphan.md"
assert_file_missing "gc: auto moves root stray to inbox" "$VAULT/random-note.md"

# Inbox should now contain the moved files
inbox_count=$(ls "$VAULT/_inbox/" | wc -l | tr -d ' ')
[[ "$inbox_count" -ge 3 ]] && _pass "gc: moved files appear in _inbox" || \
  _fail "gc: expected ≥3 files in _inbox, got $inbox_count"

# Lint check — should flag no-frontmatter (exits 3 when lint issues found)
output=$("$PRIMER_GC" --vault "$VAULT" --lint 2>&1) || true
assert_contains "gc: lint flags missing frontmatter" "NO FRONTMATTER" "$output"
assert_contains "gc: lint flags duplicate slugs" "DUPLICATE SLUG" "$output"

# Files in _inbox/ should NOT be flagged for missing frontmatter
[[ "$output" != *"raw-capture"* ]] && _pass "gc: _inbox files skipped by lint" || \
  _fail "gc: _inbox file incorrectly flagged for missing frontmatter"

# Known root files should never be flagged
[[ "$output" != *"README.md"* ]] && _pass "gc: README.md not flagged as stray" || \
  _fail "gc: README.md incorrectly flagged"

# ── test: .primer-gc policy file overrides defaults ──────────────────────────

# Build a second vault with a custom policy: a dir name that isn't in defaults
# should be allowed when listed in .primer-gc, and the default "1-Projects"
# should become stray when it's not listed.

VAULT2="$TEST_DIR/vault2"
mkdir -p "$VAULT2/notes/2026" "$VAULT2/1-Projects" "$VAULT2/_inbox"

echo "---" > "$VAULT2/notes/2026/note.md"       # should be allowed per policy
echo "---" > "$VAULT2/1-Projects/p.md"           # should be stray per policy

# Policy: only allow "notes", drop the SakinOS-style dirs
cat > "$VAULT2/.primer-gc" <<'POLICY'
ALLOWED_DIRS=notes
ALLOWED_ROOT_FILES=README.md
POLICY

output=$("$PRIMER_GC" --vault "$VAULT2" 2>&1) || true
[[ "$output" != *"notes/2026/note.md"* ]] && _pass "gc: policy ALLOWED_DIRS permits 'notes/'" || \
  _fail "gc: policy did not permit 'notes/' (note.md got flagged)"
[[ "$output" == *"1-Projects/p.md"* ]] && _pass "gc: policy overrides defaults (1-Projects now stray)" || \
  _fail "gc: policy did not override defaults (1-Projects still allowed)"

# Custom INBOX_DIR
VAULT3="$TEST_DIR/vault3"
mkdir -p "$VAULT3/incoming" "$VAULT3/random"
echo "---" > "$VAULT3/random/stray.md"
cat > "$VAULT3/.primer-gc" <<'POLICY'
ALLOWED_DIRS=notes
INBOX_DIR=incoming
POLICY

"$PRIMER_GC" --vault "$VAULT3" --auto > /dev/null 2>&1 || true
assert_file_exists "gc: policy INBOX_DIR routes strays to custom dir" "$VAULT3/incoming/$(ls "$VAULT3/incoming" 2>/dev/null | head -1)"

# ── test: send_keys literal + split Enter ────────────────────────────────────
#
# Regression: when the warmup message contains strings that tmux interprets as
# key names (e.g. "Enter", "C-c"), they must be sent as literal text.  Also,
# text and Enter must be sent as two separate calls so fast TUIs don't lose
# the Enter to debounce.  This test asserts the source shape of send_keys.

section "send_keys shape"

set +e
send_keys_fn=$(awk '/^send_keys\(\)/,/^}/' "$PRIMERD")

if echo "$send_keys_fn" | grep -q -- '-l[[:space:]]*"\$\*"'; then
  _pass "send_keys: uses -l (literal) for text"
else
  _fail "send_keys: does not use -l (literal) for text (regression)"
fi

# Count tmux send-keys invocations. Post-fix = 2 (text, Enter). Pre-fix = 1.
sk_calls=$(echo "$send_keys_fn" | grep -c 'tmux send-keys')
if [[ "$sk_calls" -ge 2 ]]; then
  _pass "send_keys: text and Enter sent as separate tmux calls"
else
  _fail "send_keys: text and Enter bundled in one tmux call (regression)"
fi

# ── test: PRIMER_CLI_READY_WAIT configurable ─────────────────────────────────
#
# Regression: a hardcoded 2s sleep after launching the CLI isn't enough for
# slower TUIs (Claude Code cold-starts in 5–15s).  Wait must be configurable.

section "cli ready wait"

if grep -q 'PRIMER_CLI_READY_WAIT' "$PRIMERD"; then
  _pass "primerd: PRIMER_CLI_READY_WAIT env var present"
else
  _fail "primerd: PRIMER_CLI_READY_WAIT env var missing (regression)"
fi

# Look for a hardcoded `sleep 2` immediately following a `send_keys ... "$cli"`
# (the specific anti-pattern). Poll loops that sleep 2s are legitimate.
if grep -A1 'send_keys "\$window" "\$cli"' "$PRIMERD" | grep -qE '^[[:space:]]*sleep[[:space:]]+2[[:space:]]*$'; then
  _fail "primerd: hardcoded 'sleep 2' after CLI launch (regression)"
else
  _pass "primerd: sleep after CLI launch is configurable"
fi

# ── test: per-slot pane colors ───────────────────────────────────────────────
#
# Slots get distinct tmux bg colors so they're easy to distinguish at a glance.
# Test shape of the code, not a running tmux session.

section "per-slot colors"

set +e
if grep -q 'PRIMER_SLOT_COLORS' "$PRIMERD"; then
  _pass "primerd: PRIMER_SLOT_COLORS env var present"
else
  _fail "primerd: PRIMER_SLOT_COLORS env var missing (regression)"
fi
if grep -q 'window-style' "$PRIMERD"; then
  _pass "primerd: spawn_window applies window-style"
else
  _fail "primerd: no window-style call — colors won't show (regression)"
fi
set -e

# ── test: tmux status bar disabled ───────────────────────────────────────────
#
# Regression: tmux's default status bar obscures host TUI statuslines (e.g.
# Claude Code's).  ensure_tmux_session must turn it off when creating the pool.

section "tmux status off"

ensure_fn=$(awk '/^ensure_tmux_session\(\)/,/^}/' "$PRIMERD")
if echo "$ensure_fn" | grep -q 'status off'; then
  _pass "primerd: ensure_tmux_session disables status bar"
else
  _fail "primerd: ensure_tmux_session does not disable status bar (regression)"
fi

# ── test: clear-history after warming ────────────────────────────────────────
#
# Regression: without clearing scrollback on success, the user attaches into a
# pane full of the CLI's startup output (and any prior warm attempts' leftovers).

section "clear-history on warm"

set +e
warm_fn=$(awk '/^warm_window\(\)/,/^rewarm_window\(\)/' "$PRIMERD")
if echo "$warm_fn" | grep -q 'clear-history'; then
  _pass "primerd: clears scrollback after warm"
else
  _fail "primerd: does not clear scrollback after warm (regression)"
fi
set -e

# ── test: primer attach without warm slot triggers warm ──────────────────────
#
# Regression: running `primer attach` with no warm slot should request a warm
# before attaching, not just jump into a cold pane.

section "attach triggers warm"

mkdir -p "$PRIMER_DIR/state"
for s in 0 1 2; do echo "cold" > "$PRIMER_DIR/state/slot-$s"; done
rm -f "$PRIMER_DIR"/warm-request*

# Stub tmux so do_attach does not block on a real tmux session.
mkdir -p "$TEST_DIR/stubs"
cat > "$TEST_DIR/stubs/tmux" <<'STUB'
#!/usr/bin/env bash
exit 0
STUB
chmod +x "$TEST_DIR/stubs/tmux"

PATH="$TEST_DIR/stubs:$PATH" "$PRIMER" attach > /dev/null 2>&1 || true

if [[ -f "$PRIMER_DIR/warm-request-0" ]] || [[ -f "$PRIMER_DIR/warm-request" ]]; then
  _pass "attach: warm-request created when no warm slot"
  rm -f "$PRIMER_DIR"/warm-request*
else
  _fail "attach: no warm-request created when no warm slot (regression)"
fi
set -e

# ── test: help outputs ────────────────────────────────────────────────────────

section "help"

output=$("$PRIMER" help 2>&1)
assert_contains "primer help: attach mentioned" "attach" "$output"
assert_contains "primer help: alt mentioned" "alt" "$output"
assert_contains "primer help: switch mentioned" "switch" "$output"
assert_contains "primer help: config file mentioned" "config" "$output"

output=$("$PRIMERD" help 2>&1)
assert_contains "primerd help: PRIMER_ALT_CLI mentioned" "PRIMER_ALT_CLI" "$output"
assert_contains "primerd help: config-template mentioned" "config-template" "$output"

output=$("$PRIMER_GC" --help 2>&1)
assert_contains "primer-gc help: --auto mentioned" "--auto" "$output"
assert_contains "primer-gc help: --lint mentioned" "--lint" "$output"

# ── pool lifecycle (requires tmux) ────────────────────────────────────────────

section "pool lifecycle"

if $FAST_ONLY; then
  _skip "pool: start/stop (--fast mode)"
  _skip "pool: status output"
elif ! command -v tmux &>/dev/null; then
  _skip "pool: tmux not available"
else
  # Use a mock CLI that immediately prints the warmup marker and exits
  MOCK_CLI="$TEST_DIR/mock-cli"
  cat > "$MOCK_CLI" <<'MOCK'
#!/usr/bin/env bash
echo "SESSION START — mock LLM"
read -r line   # stay alive until killed
MOCK
  chmod +x "$MOCK_CLI"

  export PRIMER_CLI="$MOCK_CLI"
  export PRIMER_MODE=lazy

  # Start daemon
  "$PRIMERD" start > /dev/null 2>&1
  sleep 1

  pid_file="$PRIMER_DIR/primerd.pid"
  if [[ -f "$pid_file" ]] && kill -0 "$(cat "$pid_file")" 2>/dev/null; then
    _pass "pool: daemon started"
  else
    _fail "pool: daemon did not start"
  fi

  # Trigger a warm and wait for slot 0 to actually reach warm state.
  # This catches regressions in warm_window where the CLI isn't launched
  # or the warmup marker isn't detected.
  "$PRIMER" warm > /dev/null 2>&1

  waited=0
  while [[ $waited -lt 15 ]]; do
    state=$(cat "$PRIMER_DIR/state/slot-0" 2>/dev/null || echo "")
    [[ "$state" == "warm" ]] && break
    sleep 1
    waited=$((waited + 1))
  done
  assert_eq "pool: slot 0 reached warm state" "warm" "$state"

  status_out=$("$PRIMER" status 2>&1) || true
  assert_contains "pool: status shows pool name" "${PRIMER_SESSION_PREFIX}-pool" "$status_out"
  assert_contains "pool: status shows slot 0" "slot 0" "$status_out"
  assert_contains "pool: status shows warm indicator" "✓" "$status_out"

  # Stop daemon
  "$PRIMERD" stop > /dev/null 2>&1
  sleep 1

  if [[ ! -f "$pid_file" ]] || ! kill -0 "$(cat "$pid_file")" 2>/dev/null; then
    _pass "pool: daemon stopped"
  else
    _fail "pool: daemon still running after stop"
  fi

  # Clean up tmux session
  tmux kill-session -t "${PRIMER_SESSION_PREFIX}-pool" 2>/dev/null || true
fi

# ── summary ───────────────────────────────────────────────────────────────────

echo ""
echo "── Results ─────────────────────────────────────────────────"
printf "  ✓ passed: %s\n" "$PASS"
printf "  ✗ failed: %s\n" "$FAIL"
printf "  ⊘ skipped: %s\n" "$SKIP"

if [[ ${#_failures[@]} -gt 0 ]]; then
  echo ""
  echo "  Failed tests:"
  for f in "${_failures[@]}"; do
    echo "    • $f"
  done
fi
echo "────────────────────────────────────────────────────────────"

[[ "$FAIL" -eq 0 ]]

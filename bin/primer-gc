#!/usr/bin/env bash
# primer-gc — llm-primer garbage collector
#
# Scans a vault directory for files that ended up in the wrong place and
# moves them into _inbox/ so they can flow through the normal filing process.
#
# Usage:
#   primer-gc --vault /path/to/vault           # dry run (show what would move)
#   primer-gc --vault /path/to/vault --auto    # move stray files automatically
#   primer-gc --vault /path/to/vault --lint    # flag frontmatter issues only
#   primer gc /path/to/vault                   # via primer CLI wrapper
#
# Invoked automatically by primerd when PRIMER_GC_VAULT is set.

set -euo pipefail

# ── defaults ──────────────────────────────────────────────────────────────────

VAULT=""
AUTO=false
LINT_ONLY=false
VERBOSE=false

# Directories where .md files are always allowed.
# Any directory whose name starts with _ is automatically allowed.
# Root-level files with these exact names are always allowed.
ALLOWED_ROOT_FILES=(
  "README.md"
  "PHILOSOPHY.md"
  "CLAUDE.md"
  "GEMINI.md"
  "AGENTS.md"
  "CURSOR.md"
  "COPILOT.md"
  "LICENSE"
  "LICENSE.md"
  "CONTRIBUTING.md"
  "CHANGELOG.md"
)

# Top-level directories where .md files are always allowed.
# Any _* directory is auto-allowed. These are the named ones.
ALLOWED_DIRS=(
  "0-Ideas"
  "1-Projects"
  "2-Knowledge"
  "3-Journal"
  "4-Private"
  "5-Publishing"
  "6-Experiments"
  "7-Family"
  "docs"
  "examples"
)

# File extensions considered "assets" — never moved regardless of location.
ASSET_EXTENSIONS=("png" "jpg" "jpeg" "gif" "svg" "webp" "pdf" "mp4" "mov" "mp3"
                  "zip" "tar" "gz" "sh" "py" "js" "ts" "go" "rb" "json" "toml"
                  "yaml" "yml" "css" "html" "txt" "csv")

# ── argument parsing ──────────────────────────────────────────────────────────

while [[ $# -gt 0 ]]; do
  case "$1" in
    --vault|-v)
      VAULT="$2"
      shift 2
      ;;
    --auto|-a)
      AUTO=true
      shift
      ;;
    --lint|-l)
      LINT_ONLY=true
      shift
      ;;
    --verbose)
      VERBOSE=true
      shift
      ;;
    --help|-h)
      cat <<'HELP'
primer-gc — llm-primer garbage collector

Finds files that drifted into the wrong place in your vault and moves them
into _inbox/ so they flow through the normal filing process.

Usage:
  primer-gc --vault <path>              Dry run — show what would be moved
  primer-gc --vault <path> --auto       Move stray files automatically
  primer-gc --vault <path> --lint       Flag frontmatter and naming issues only
  primer-gc --vault <path> --verbose    Show all files checked

Options:
  --vault, -v   Path to vault root (required)
  --auto, -a    Move stray files without prompting
  --lint, -l    Frontmatter and naming checks only (no file moves)
  --verbose     Print every file checked
  --help        Show this help

What counts as "stray":
  Any .md file that is:
  - Not in _inbox/, _output/, _meta/, _config/, _divergence/, _seeds/, or any _* dir
  - Not in a named allowed directory (0-Ideas/, 1-Projects/, etc.)
  - Not a known root-level file (README.md, PHILOSOPHY.md, CLAUDE.md, etc.)

Exceptions (never moved):
  - Files in any _* directory
  - Asset files (.png, .pdf, .sh, .py, etc.)
  - Files in explicitly allowed directories (configurable via GC_ALLOWED_DIRS)
  - Symlinks

Additional checks (--lint):
  - .md files without a frontmatter block (--- ... ---)
  - .md files with dates that don't match the YYYY-MM-DD-slug.md naming standard
  - Duplicate file slugs across the vault
HELP
      exit 0
      ;;
    *)
      echo "Unknown option: $1. Run 'primer-gc --help' for usage." >&2
      exit 1
      ;;
  esac
done

[[ -z "$VAULT" ]] && { echo "error: --vault is required" >&2; exit 1; }
[[ -d "$VAULT" ]] || { echo "error: vault not found: $VAULT" >&2; exit 1; }

# Support additional allowed dirs from env
if [[ -n "${GC_ALLOWED_DIRS:-}" ]]; then
  IFS=',' read -ra extra_dirs <<< "$GC_ALLOWED_DIRS"
  ALLOWED_DIRS+=("${extra_dirs[@]}")
fi

# ── helpers ───────────────────────────────────────────────────────────────────

log()  { echo "$(date '+%Y-%m-%d %H:%M:%S') gc: $*"; }
info() { echo "  → $*"; }
warn() { echo "  ⚠ $*"; }

is_asset() {
  local file="$1"
  local ext="${file##*.}"
  for a in "${ASSET_EXTENSIONS[@]}"; do
    [[ "$ext" == "$a" ]] && return 0
  done
  return 1
}

is_allowed_path() {
  local rel="$1"   # path relative to vault root

  # Root-level files (no directory separator)
  if [[ "$rel" != */* ]]; then
    local base
    base=$(basename "$rel")
    for f in "${ALLOWED_ROOT_FILES[@]}"; do
      [[ "$base" == "$f" ]] && return 0
    done
    # Anything directly at root that isn't a known file is stray
    return 1
  fi

  # Extract top-level directory
  local topdir
  topdir="${rel%%/*}"

  # Any _* directory is always allowed
  [[ "$topdir" == _* ]] && return 0

  # Named allowed directories
  for d in "${ALLOWED_DIRS[@]}"; do
    [[ "$topdir" == "$d" ]] && return 0
  done

  return 1
}

has_frontmatter() {
  local file="$1"
  head -1 "$file" 2>/dev/null | grep -q "^---"
}

matches_naming_standard() {
  local base="$1"
  # Standard: YYYY-MM-DD-slug.md (lowercase, hyphens)
  [[ "$base" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}-[a-z0-9-]+\.md$ ]]
}

# ── inbox move ────────────────────────────────────────────────────────────────

move_to_inbox() {
  local file="$1"
  local inbox="$VAULT/_inbox"
  mkdir -p "$inbox"

  local base
  base=$(basename "$file")
  local today
  today=$(date '+%Y-%m-%d')

  # Prefix with today's date if not already dated
  local target_name
  if [[ "$base" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2} ]]; then
    target_name="$base"
  else
    # Slugify: lowercase, replace spaces with hyphens
    local slug
    slug=$(echo "$base" | tr '[:upper:]' '[:lower:]' | tr ' ' '-')
    target_name="${today}-${slug}"
  fi

  local target="$inbox/$target_name"

  # Avoid clobbering existing inbox file
  if [[ -f "$target" ]]; then
    target="$inbox/${today}-gc-$(basename "$file")"
  fi

  if $AUTO; then
    mv "$file" "$target"
    log "MOVED: $file → _inbox/$(basename "$target")"
  else
    info "would move: $file → _inbox/$(basename "$target")"
  fi
}

# ── main scan ─────────────────────────────────────────────────────────────────

stray_count=0
lint_count=0
moved_count=0

log "Scanning vault: $VAULT"
$AUTO && log "Mode: auto (files will be moved)"
$LINT_ONLY && log "Mode: lint only (no moves)"

# Find all .md files, excluding git internals
while IFS= read -r -d '' file; do
  # Skip symlinks
  [[ -L "$file" ]] && continue

  rel="${file#$VAULT/}"

  $VERBOSE && info "checking: $rel"

  # Asset check (by extension)
  is_asset "$rel" && continue

  # ── stray check ──
  if ! $LINT_ONLY && ! is_allowed_path "$rel"; then
    stray_count=$((stray_count + 1))
    if $AUTO; then
      move_to_inbox "$file"
      moved_count=$((moved_count + 1))
    else
      warn "STRAY: $rel"
    fi
    continue
  fi

  # ── lint checks (run on all .md files in allowed locations) ──
  if ! has_frontmatter "$file"; then
    lint_count=$((lint_count + 1))
    warn "NO FRONTMATTER: $rel"
  fi

done < <(find "$VAULT" -name "*.md" -not -path "*/.git/*" -print0)

# ── duplicate slug check ──────────────────────────────────────────────────────

log "Checking for duplicate slugs..."
declare -A seen_slugs
while IFS= read -r -d '' file; do
  [[ -L "$file" ]] && continue
  base=$(basename "$file" .md)
  # Strip date prefix for slug comparison
  slug="${base#????-??-??-}"
  if [[ -n "${seen_slugs[$slug]:-}" ]]; then
    lint_count=$((lint_count + 1))
    warn "DUPLICATE SLUG '$slug': $file  (also: ${seen_slugs[$slug]})"
  else
    seen_slugs["$slug"]="$file"
  fi
done < <(find "$VAULT" -name "*.md" -not -path "*/.git/*" -print0)

# ── summary ───────────────────────────────────────────────────────────────────

echo ""
echo "── GC Summary ─────────────────────────────────────────────"
if $AUTO; then
  echo "  Moved to _inbox: $moved_count"
else
  echo "  Stray files found: $stray_count"
  [[ $stray_count -gt 0 ]] && echo "  Run with --auto to move them to _inbox/"
fi
echo "  Lint issues found: $lint_count"
[[ $lint_count -gt 0 ]] && echo "  (no-frontmatter files and duplicate slugs — fix manually)"
echo "───────────────────────────────────────────────────────────"

[[ $stray_count -gt 0 ]] && ! $AUTO && exit 2
[[ $lint_count -gt 0 ]] && exit 3
exit 0
